---
interface Project {
  title: string;
  location: string;
  service: string;
  description: string;
  imageSrc: string;
  imageAlt: string;
  href?: string;
}

interface Props {
  heading?: string;
  overline?: string;
  projects: Project[];
  showLink?: boolean;
}

const {
  heading  = 'Custom Home Theater and AV Projects',
  overline = 'Recent Work',
  projects,
  showLink = true,
} = Astro.props;

const delayClasses = ['reveal-delay-2','reveal-delay-3','reveal-delay-4','reveal-delay-5','reveal-delay-6','reveal-delay-6'];
---

<section class="section bg-charcoal">
  <div class="container-main">
    <p class="overline mb-3 reveal">{overline}</p>
    <h2 class="font-display text-h2 text-warm-white mb-3 reveal reveal-delay-1">{heading}</h2>
    <p class="text-body-sm text-stone mb-10 reveal reveal-delay-2" style="max-width:48ch;">Every project below was designed, installed, and programmed by our team — no subcontractors.</p>

    <!-- Portrait-friendly grid: 3 columns on desktop, 2 on tablet, 1 on mobile -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map(({ title, location, service, description, imageSrc, imageAlt, href }, i) => (
        href ? (
          <a
            href={href}
            class:list={[
              'group overflow-hidden rounded-card reveal cursor-pointer no-underline',
              'flex flex-col',
              delayClasses[Math.min(i, 5)],
            ]}
            style="background:#161A1E; border:1px solid #252A2F; transition: border-color 300ms ease, box-shadow 300ms ease, transform 300ms ease;"
            aria-label={`View project: ${title}`}
          >
            <!-- Portrait image container — 3:4 ratio -->
            <div class="overflow-hidden" style="aspect-ratio:3/4; position:relative;">
              <img
                src={imageSrc}
                alt={imageAlt}
                class="w-full h-full object-cover object-top transition-transform duration-slow group-hover:scale-[1.04]"
                loading="lazy"
                decoding="async"
              />
              <!-- Subtle bottom gradient -->
              <div class="absolute bottom-0 left-0 right-0 h-24 pointer-events-none"
                style="background: linear-gradient(to top, rgba(22,26,30,0.85) 0%, transparent 100%);"
              ></div>
              <!-- Service badge top-right -->
              <div class="absolute top-3 right-3">
                <span class="text-[0.65rem] font-sans font-600 uppercase tracking-widest px-2 py-1 rounded"
                  style="background:rgba(14,16,18,0.75);backdrop-filter:blur(8px);color:#C9A84C;border:1px solid rgba(201,168,76,0.25);">
                  {service}
                </span>
              </div>
            </div>

            <!-- Card content -->
            <div class="p-5 flex flex-col flex-1">
              <p class="text-[0.7rem] font-sans uppercase tracking-widest text-stone mb-2">{location}</p>
              <h3 class="font-sans font-semibold text-warm-white mb-3 leading-snug" style="font-size:1rem;">{title}</h3>
              <p class="text-body-sm text-stone leading-relaxed text-[0.875rem] flex-1">{description}</p>
              <p class="mt-4 text-gold text-[0.8rem] font-sans font-semibold uppercase tracking-wider transition-colors duration-fast group-hover:text-gold-light">
                View Full Project →
              </p>
            </div>
          </a>
        ) : (
        <div
          class:list={[
            'group overflow-hidden rounded-card reveal cursor-pointer no-underline',
            'flex flex-col kz-lb-trigger',
            delayClasses[Math.min(i, 5)],
          ]}
          data-img={imageSrc}
          data-alt={imageAlt}
          data-title={title}
          data-desc={description}
          style="background:#161A1E; border:1px solid #252A2F; transition: border-color 300ms ease, box-shadow 300ms ease, transform 300ms ease;"
          role="button"
          tabindex="0"
          aria-label={`View photo: ${title}`}
        >
          <!-- Portrait image container — 3:4 ratio -->
          <div class="overflow-hidden" style="aspect-ratio:3/4; position:relative;">
            <img
              src={imageSrc}
              alt={imageAlt}
              class="w-full h-full object-cover object-top transition-transform duration-slow group-hover:scale-[1.04]"
              loading="lazy"
              decoding="async"
            />
            <!-- Subtle bottom gradient -->
            <div class="absolute bottom-0 left-0 right-0 h-24 pointer-events-none"
              style="background: linear-gradient(to top, rgba(22,26,30,0.85) 0%, transparent 100%);"
            ></div>
            <!-- Service badge top-right -->
            <div class="absolute top-3 right-3">
              <span class="text-[0.65rem] font-sans font-600 uppercase tracking-widest px-2 py-1 rounded"
                style="background:rgba(14,16,18,0.75);backdrop-filter:blur(8px);color:#C9A84C;border:1px solid rgba(201,168,76,0.25);">
                {service}
              </span>
            </div>
          </div>

          <!-- Card content -->
          <div class="p-5 flex flex-col flex-1">
            <p class="text-[0.7rem] font-sans uppercase tracking-widest text-stone mb-2">{location}</p>
            <h3 class="font-sans font-semibold text-warm-white mb-3 leading-snug" style="font-size:1rem;">{title}</h3>
            <p class="text-body-sm text-stone leading-relaxed text-[0.875rem] flex-1">{description}</p>
            <p class="mt-4 text-gold text-[0.8rem] font-sans font-semibold uppercase tracking-wider transition-colors duration-fast group-hover:text-gold-light">
              View photo →
            </p>
          </div>
        </div>
        )
      ))}
    </div>

    {showLink && (
      <div class="mt-12 text-center">
        <a href="/home-theater-projects-san-antonio/" class="btn-ghost">
          See All Projects
        </a>
      </div>
    )}
  </div>
</section>

<!-- Lightbox overlay -->
<div
  id="kz-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Project photo"
  style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(14,16,18,0.96); cursor:pointer; backdrop-filter:blur(8px);"
>
  <button
    id="kz-lb-close"
    aria-label="Close photo"
    style="position:absolute;top:1.25rem;right:1.5rem;background:none;border:none;color:#F2EDE6;font-size:1.75rem;cursor:pointer;line-height:1;opacity:0.7;transition:opacity 150ms;"
    onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'"
  >&#x2715;</button>
  <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:5rem 1.5rem 2rem;">
    <img
      id="kz-lb-img"
      src=""
      alt=""
      style="max-width:100%;max-height:78vh;object-fit:contain;border-radius:0.375rem;box-shadow:0 32px 80px rgba(0,0,0,0.8);"
    />
    <div style="margin-top:1.25rem;text-align:center;">
      <p id="kz-lb-title" style="font-family:'Jost',sans-serif;color:#F2EDE6;font-size:0.9rem;font-weight:600;margin-bottom:0.35rem;"></p>
      <p id="kz-lb-desc" style="font-family:'Jost',sans-serif;color:#A09080;font-size:0.8rem;max-width:48ch;line-height:1.6;"></p>
    </div>
  </div>
</div>

<script>
  const lb      = document.getElementById('kz-lightbox') as HTMLElement;
  const lbImg   = document.getElementById('kz-lb-img')   as HTMLImageElement;
  const lbTitle = document.getElementById('kz-lb-title') as HTMLElement;
  const lbDesc  = document.getElementById('kz-lb-desc')  as HTMLElement;
  const lbClose = document.getElementById('kz-lb-close') as HTMLElement;

  function openLightbox(img: string, alt: string, title: string, desc: string) {
    lbImg.src      = img;
    lbImg.alt      = alt;
    lbTitle.textContent = title;
    lbDesc.textContent  = desc;
    lb.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lb.style.display = 'none';
    document.body.style.overflow = '';
    lbImg.src = '';
  }

  document.querySelectorAll<HTMLElement>('.kz-lb-trigger').forEach(el => {
    const open = () => openLightbox(
      el.dataset.img   ?? '',
      el.dataset.alt   ?? '',
      el.dataset.title ?? '',
      el.dataset.desc  ?? '',
    );
    el.addEventListener('click', open);
    el.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); } });
  });

  lb.addEventListener('click', (e) => { if (e.target !== lbImg) closeLightbox(); });
  lbClose.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Escape') closeLightbox(); });
</script>

<style>
  /* Card hover state */
  .group:hover {
    border-color: rgba(201,168,76,0.45) !important;
    box-shadow: 0 0 40px rgba(201,168,76,0.10), 0 12px 40px rgba(0,0,0,0.55);
    transform: translateY(-3px);
  }
</style>
