---
interface Project {
  title: string;
  location: string;
  service: string;
  description: string;
  imageSrc: string;
  imageAlt: string;
  href?: string;
}

interface Props {
  heading?: string;
  overline?: string;
  projects: Project[];
  showLink?: boolean;
}

const {
  heading  = 'Custom Home Theater and AV Projects',
  overline = 'Recent Work',
  projects,
  showLink = true,
} = Astro.props;
---

<section class="section bg-charcoal">
  <div class="container-main">
    <p class="overline mb-3">{overline}</p>
    <h2 class="font-display text-h2 text-warm-white mb-10">{heading}</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map(({ title, location, service, description, imageSrc, imageAlt, href }) => {
        const Tag = href ? 'a' : 'div';
        return (
          <Tag
            href={href}
            class:list={[
              'card group overflow-hidden',
              href ? 'card-hover cursor-pointer no-underline' : '',
            ]}
          >
            <!-- Image -->
            <div class="aspect-video overflow-hidden">
              <img
                src={imageSrc}
                alt={imageAlt}
                class="w-full h-full object-cover transition-transform duration-base group-hover:scale-[1.03]"
                loading="lazy"
              />
            </div>
            <!-- Content -->
            <div class="p-6">
              <p class="text-caption text-stone uppercase tracking-widest mb-2">
                {location} &middot; {service}
              </p>
              <h3 class="font-sans font-semibold text-h4 text-warm-white mb-3">{title}</h3>
              <p class="text-body-sm text-stone leading-relaxed">{description}</p>
            </div>
          </Tag>
        );
      })}
    </div>

    {showLink && (
      <div class="mt-10 text-center">
        <a href="/home-theater-projects-san-antonio/" class="btn-ghost">
          See All Projects
        </a>
      </div>
    )}
  </div>
</section>
