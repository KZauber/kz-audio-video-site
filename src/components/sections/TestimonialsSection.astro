---
interface Testimonial {
  name: string;
  location: string;
  service: string;
  quote: string;
}

interface Props {
  heading?: string;
  featured: Testimonial;
  secondary?: Testimonial[];
}

const {
  heading = 'What Clients Say',
  featured,
  secondary = [],
} = Astro.props;

const stars = Array(5).fill(null);
---

<section class="section" style="background:#0E1012;">
  <div class="container-main">

    <!-- Section header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12 reveal">
      <div>
        <p class="overline mb-3">{heading}</p>
        <h2 class="font-display text-h2 text-warm-white">Trusted by San Antonio Homeowners</h2>
      </div>
      <!-- Google rating badge -->
      <div class="flex items-center gap-3 flex-shrink-0 glass-card px-4 py-3">
        <div class="flex gap-0.5">
          {stars.map(() => (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#C9A84C" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </div>
        <div>
          <p class="text-warm-white font-sans font-semibold text-sm leading-tight">5.0</p>
          <p class="text-stone text-[0.65rem] uppercase tracking-wider leading-tight">19 Google Reviews</p>
        </div>
      </div>
    </div>

    <!-- Featured quote — large and dramatic -->
    <blockquote class="relative mb-10 reveal reveal-delay-1">
      <!-- Large decorative quote mark -->
      <span class="absolute -top-4 -left-2 font-display text-gold opacity-20 select-none leading-none" style="font-size:8rem;line-height:1;">&ldquo;</span>
      <div class="relative pl-8 border-l-2 border-gold py-2">
        <p class="font-display italic text-warm-white leading-relaxed mb-6" style="font-size:clamp(1.15rem,2vw,1.4rem);">
          &ldquo;{featured.quote}&rdquo;
        </p>
        <footer class="flex items-center gap-3">
          <span class="block w-6 h-px bg-gold opacity-60"></span>
          <span class="text-stone text-[0.75rem] font-sans uppercase tracking-widest">
            {featured.name} &middot; {featured.location} &middot; {featured.service}
          </span>
        </footer>
      </div>
    </blockquote>

    <!-- Secondary cards -->
    {secondary.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {secondary.map((t, i) => (
          <blockquote
            class:list={['glass-card p-6 reveal', i === 0 ? 'reveal-delay-2' : 'reveal-delay-3']}
          >
            <!-- Stars -->
            <div class="flex gap-0.5 mb-4">
              {stars.map(() => (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="#C9A84C" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <p class="text-warm-white font-sans leading-relaxed mb-5" style="font-size:0.9375rem;">
              &ldquo;{t.quote}&rdquo;
            </p>
            <footer class="flex items-center gap-2">
              <span class="block w-4 h-px bg-gold opacity-50"></span>
              <span class="text-stone text-[0.7rem] font-sans uppercase tracking-widest">
                {t.name} &middot; {t.location}
              </span>
            </footer>
          </blockquote>
        ))}
      </div>
    )}

  </div>
</section>
