---
interface Props {
  overline?: string;
  heading: string;
  subhead: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryCta?: string;
  secondaryHref?: string;
  imageSrc: string;
  imageAlt: string;
  videoSrc?: string;
  align?: 'left' | 'center';
  /** Pass true to shrink the H1 for pages where the default hero size is too large */
  compact?: boolean;
  /** Pass true to use a lighter gradient overlay */
  lightGradient?: boolean;
  /** Tailwind object-position class for the background image, e.g. 'object-top', 'object-center', 'object-bottom' */
  imagePosition?: string;
  /** Push the image down by this many pixels so top content is visible */
  imagePushDown?: number;
}

const {
  overline,
  heading,
  subhead,
  ctaLabel,
  ctaHref  = '/contact-kz-audio-video-san-antonio-tx/',
  secondaryCta,
  secondaryHref = 'tel:2109814098',
  imageSrc,
  imageAlt,
  videoSrc,
  align = 'left',
  compact = false,
  lightGradient = false,
  imagePosition = 'object-top',
  imagePushDown = 0,
} = Astro.props;
---

<section class="relative w-full min-h-screen flex items-end overflow-hidden" style="background:#0E1012;">

  <!-- Full-bleed background: video (when provided) or image fallback -->
  <div class="absolute inset-0 hero-enter-img" style={`transform: translateY(${imagePushDown}px);`} aria-hidden="true">

    {videoSrc ? (
      /* ── VIDEO BACKGROUND ───────────────────────────────────────────────
         poster= shows the image instantly while the video buffers.
         autoplay muted loop playsinline are required for browser autoplay. */
      <video
        class="w-full h-full object-cover object-center"
        autoplay
        muted
        loop
        playsinline
        poster={imageSrc}
        aria-hidden="true"
        preload="auto"
      >
        <source src={videoSrc} type="video/mp4" />
        {/* Fallback: show poster image if video fails */}
        <img src={imageSrc} alt="" aria-hidden="true" class="w-full h-full object-cover" />
      </video>
    ) : (
      /* ── IMAGE BACKGROUND (location pages + any page without video) ─── */
      <img
        src={imageSrc}
        alt=""
        aria-hidden="true"
        class={`w-full h-full object-cover ${imagePosition}`}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    )}

    <!-- Cinematic vignette: left + bottom darkening -->
    <div
      class="absolute inset-0"
      style={lightGradient
        ? `background:
            linear-gradient(to right, rgba(14,16,18,0.45) 0%, rgba(14,16,18,0.18) 30%, rgba(14,16,18,0.02) 52%, rgba(14,16,18,0.00) 100%),
            linear-gradient(to top, rgba(14,16,18,0.28) 0%, rgba(14,16,18,0.06) 25%, transparent 50%),
            linear-gradient(to bottom, rgba(14,16,18,0.08) 0%, transparent 12%)`
        : `background:
            linear-gradient(to right, rgba(14,16,18,0.68) 0%, rgba(14,16,18,0.28) 30%, rgba(14,16,18,0.04) 52%, rgba(14,16,18,0.00) 100%),
            linear-gradient(to top, rgba(14,16,18,0.48) 0%, rgba(14,16,18,0.10) 25%, transparent 50%),
            linear-gradient(to bottom, rgba(14,16,18,0.14) 0%, transparent 12%)`}
      aria-hidden="true"
    ></div>
    <!-- Subtle gold atmosphere at bottom-left -->
    <div
      class="absolute bottom-0 left-0 w-[500px] h-[280px] pointer-events-none"
      style="background: radial-gradient(ellipse at 0% 100%, rgba(201,168,76,0.07) 0%, transparent 70%)"
      aria-hidden="true"
    ></div>
  </div>

  <!-- Content — anchored to bottom for cinematic feel -->
  <div class="relative z-10 w-full container-wide px-6 sm:px-8 lg:px-12 pb-10 md:pb-28 pt-40">
    <div class:list={[
      'max-w-[280px] sm:max-w-sm lg:max-w-md',
      align === 'center' ? 'mx-auto text-center' : '',
    ]}>

      {overline && (
        <p class="overline mb-4 md:mb-6 hero-enter-1 flex items-center gap-3" style="letter-spacing:0.18em;">
          <span class="block w-10 h-px opacity-70" style="background:linear-gradient(90deg,#C9A84C,transparent);"></span>
          {overline}
        </p>
      )}

      <h1
        class:list={['font-display text-warm-white hero-enter-2', compact ? 'text-h3 md:text-h1' : 'text-h2 md:text-hero']}
        style="letter-spacing:-0.03em;line-height:1.05;"
      >
        {heading}
      </h1>

      <p class="text-body-sm text-stone mb-5 md:mb-10 max-w-lg hero-enter-3 md:text-body-lg" style="line-height:1.7;">
        {subhead}
      </p>

      {ctaLabel && (
        <div class:list={[
          'flex flex-col sm:flex-row gap-4 hero-enter-4',
          align === 'center' ? 'justify-center' : '',
        ]}>
          <a href={ctaHref} class="btn-primary gold-shimmer">
            {ctaLabel}
          </a>
          {secondaryCta && (
            <a href={secondaryHref} class="btn-ghost">
              {secondaryCta}
            </a>
          )}
        </div>
      )}

    </div>
  </div>

</section>
