---
interface Props {
  heading?: string;
  overline?: string;
  intro?: string;
}

const {
  heading  = 'Every AV Service Your Home Needs, One Team',
  overline = 'What We Install',
  intro,
} = Astro.props;

const delayClasses = ['reveal-delay-1','reveal-delay-2','reveal-delay-3','reveal-delay-4','reveal-delay-5','reveal-delay-6'];

const services = [
  {
    title: 'Home Theater',
    desc:  'Dedicated theater rooms and media spaces built around your room, your projector, and how your family actually watches.',
    href:  '/home-theater-installation-san-antonio-tx/',
    icon:  'M21 3H3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H3V5h18v14zm-10-7H8v-2h3V7h2v3h3v2h-3v3h-2v-3z',
  },
  {
    title: 'Whole House Audio',
    desc:  'Music in every room, controlled from your phone. Designed around how you use your home — not a one-size spec sheet.',
    href:  '/whole-house-audio-san-antonio/',
    icon:  'M12 3v9.28a4.39 4.39 0 0 0-1.5-.28C8.01 12 6 14.01 6 16.5S8.01 21 10.5 21c2.31 0 4.2-1.75 4.45-4H15V6h4V3h-7z',
  },
  {
    title: 'Outdoor Audio & Video',
    desc:  'Covered patios, pool decks, and outdoor kitchens. Weather-resistant speakers and displays installed clean.',
    href:  '/outdoor-audio-video-san-antonio/',
    icon:  'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  },
  {
    title: 'Surround Sound',
    desc:  '5.1, 7.1, Dolby Atmos — properly placed, properly calibrated. Not just plugged in and set to default.',
    href:  '/surround-sound-installation-san-antonio/',
    icon:  'M20 6c0-2.21-3.58-4-8-4S4 3.79 4 6v12c0 2.21 3.58 4 8 4s8-1.79 8-4V6zm-8 14c-3.31 0-6-1.12-6-2.5V9.37C7.45 10.4 9.61 11 12 11s4.55-.6 6-1.63V17.5c0 1.38-2.69 2.5-6 2.5z',
  },
  {
    title: 'Security Cameras',
    desc:  'Indoor and outdoor camera systems integrated into your home technology setup. Professional installation, remote access.',
    href:  '/security-camera-installation-san-antonio/',
    icon:  'M12 1C5.925 1 1 5.925 1 12s4.925 11 11 11 11-4.925 11-11S18.075 1 12 1zm0 4a4 4 0 1 1 0 8 4 4 0 0 1 0-8zm0 14.5a7.5 7.5 0 0 1-5.4-2.297A6.98 6.98 0 0 1 12 16a6.98 6.98 0 0 1 5.4 1.203A7.5 7.5 0 0 1 12 19.5z',
  },
  {
    title: 'AV Repair',
    desc:  "System acting up? We work on systems we didn't install. If it can be fixed, we'll tell you.",
    href:  '/av-repair-san-antonio-tx/',
    icon:  'M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z',
  },
];
---

<section class="section bg-charcoal">
  <div class="container-main">
    <p class="overline mb-3 reveal">{overline}</p>
    <h2 class="font-display text-h2 text-warm-white mb-4 reveal reveal-delay-1">{heading}</h2>
    {intro && <p class="text-body-lg text-stone mb-12 max-w-2xl reveal reveal-delay-2">{intro}</p>}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-10">
      {services.map(({ title, desc, href, icon }, i) => (
        <a
          href={href}
          class:list={["card card-hover p-7 flex flex-col gap-4 group no-underline reveal", delayClasses[Math.min(i, 5)]]}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24" height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#C9A84C"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d={icon} />
          </svg>
          <h3 class="font-sans font-semibold text-h4 text-warm-white">{title}</h3>
          <p class="text-body-sm text-stone leading-relaxed flex-1">{desc}</p>
          <span class="btn-text text-sm">See details &rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>
