---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroSection from "../../components/sections/HeroSection.astro";
import TrustBar from "../../components/sections/TrustBar.astro";
import ProjectsGrid from "../../components/sections/ProjectsGrid.astro";
import TestimonialsSection from "../../components/sections/TestimonialsSection.astro";
import FAQAccordion from "../../components/sections/FAQAccordion.astro";
import CTASection from "../../components/sections/CTASection.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Home Theater Installation San Antonio TX",
  "provider": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "url": "https://kzaudioandvideo.com",
    "telephone": "+12109814098"
  },
  "areaServed": ["San Antonio", "Boerne", "Canyon Lake", "Helotes", "Bulverde", "Stone Oak", "New Braunfels"],
  "description": "Custom home theater design and installation in San Antonio TX and the Texas Hill Country. Dedicated theater rooms, 4K and laser projection, Dolby Atmos surround sound.",
  "url": "https://kzaudioandvideo.com/home-theater-installation-san-antonio-tx/"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Home Theater Installation San Antonio TX" }
  ]
};

const projects = [
  {
    title: "Dedicated Home Theater — Canyon Lake TX",
    location: "Canyon Lake, TX",
    service: "Home Theater",
    description: "Full theater room with custom leather power recliner seating on a raised platform, blue LED accent lighting, 4K projection system, and in-wall Dolby Atmos surround sound.",
    imageSrc: "/images/projects/monty-theater/Canyon-Lake-Tesac-Home-Theater-Custom-Seating.jpeg.jpg",
    imageAlt: "Custom home theater with leather recliners and blue LED lighting in Canyon Lake Texas",
  },
  {
    title: "Dedicated Home Theater — San Antonio TX",
    location: "San Antonio, TX",
    service: "Home Theater",
    description: "Epson projector, Screen Innovations fixed-frame screen, Martin Logan on-wall speakers, LED accent lighting. Pre-wire through finished install.",
    imageSrc: "/images/projects/asanka-theater/theater-room-san-antonio-tx.jpg",
    imageAlt: "Home theater installation in San Antonio Texas with projection screen and surround sound",
  },
  {
    title: "Dedicated Home Theater — David — San Antonio",
    location: "San Antonio, TX",
    service: "Home Theater",
    description: "Dedicated theater room with 4K laser projector and 7.2.4 Dolby Atmos surround sound. Built around the specific room dimensions.",
    imageSrc: "/images/projects/davids-theater/david-theater-san-antonio-tx.jpg",
    imageAlt: "Custom home theater build San Antonio Texas with Dolby Atmos surround sound",
  },
];

const featured = {
  name: "Canyon Lake Homeowner",
  location: "Canyon Lake, TX",
  service: "Dedicated Home Theater",
  quote: "Billy, Julien and Kelly did an outstanding job on my home theater build. From start to finish they were professional, knowledgeable, and easy to work with. The theater came out better than I had hoped.",
};

const secondary = [
  {
    name: "San Antonio Homeowner",
    location: "San Antonio, TX",
    service: "Home Theater",
    quote: "KZ Audio and Video did a great job installing our home theater system. They were professional, on time, and their attention to detail was outstanding.",
  },
  {
    name: "San Antonio Homeowner",
    location: "San Antonio, TX",
    service: "Home AV Client — Nearly 10 Years",
    quote: "They are honest and will recommend what actually works for your situation rather than upselling you on equipment you do not need. I have never had a bad experience with them.",
  },
];

const faqs = [
  {
    question: "How much does a home theater installation cost in San Antonio?",
    answer: "Home theater costs vary based on scope. A mid-tier dedicated theater room typically runs $15,000-$40,000 installed. High-end theaters with laser projectors, Dolby Atmos, and motorized seating run $40,000-$80,000+. A media room conversion can be done for $5,000-$12,000. We give you a detailed quote after seeing the space.",
  },
  {
    question: "Do you handle the pre-wire and the finish work, or just one?",
    answer: "We handle the full project: pre-wire, equipment selection, finish installation, calibration, and the homeowner walkthrough. We work with your builder during new construction or handle the retrofit ourselves in existing homes.",
  },
  {
    question: "What projector brands do you install?",
    answer: "We install Epson, Sony, BenQ, and JVC 4K projectors depending on room size, ambient light, and budget. For high-end dedicated theaters, Sony laser projectors deliver exceptional image quality. We match the projector to your room.",
  },
  {
    question: "Can you build a theater in a room that is already finished?",
    answer: "Yes. Retrofit installs in finished rooms require fishing wire through walls and ceilings. We have done hundreds of these. Drywall impact is minimal. We will assess the specific room and tell you exactly what is involved before we start.",
  },
  {
    question: "What is Dolby Atmos and do I need it?",
    answer: "Dolby Atmos adds overhead sound channels so audio moves three-dimensionally around the room. For a dedicated room we typically recommend it. For a living room media setup, a standard 5.1 or 7.1 system often makes more practical sense. We give you an honest recommendation based on your space.",
  },
  {
    question: "How long does a home theater installation take?",
    answer: "A full dedicated theater room typically takes two to four days after rough-in. A media room conversion is usually one to two days. We give you a timeline before we start and stick to it.",
  },
];
---

<BaseLayout
  title="Home Theater Installation San Antonio TX | KZ Audio & Video"
  description="Custom home theater installation in San Antonio TX and the Hill Country. Dedicated theater rooms, 4K projection, Dolby Atmos surround, media room conversions. In the audio business since 1997. Call (210) 981-4098."
  schema={[schema, breadcrumb]}
>

  <HeroSection
    overline="Home Theater Installation · San Antonio · Hill Country · Since 1997"
    heading="Custom Home Theater Installation in San Antonio TX"
    subhead="KZ Audio & Video designs and installs dedicated home theater rooms, media spaces, and projection systems across San Antonio and the Texas Hill Country. 4K and laser projectors, Dolby Atmos surround sound, custom seating. In the audio business since 1997."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryCta="Or call: (210) 981-4098"
    secondaryHref="tel:2109814098"
    imageSrc="/images/projects/monty-theater/hero-theater-fixed.jpg"
    imageAlt="Custom dedicated home theater installation in San Antonio Texas by KZ Audio and Video"
  />

  <TrustBar />

  <section class="section bg-slate-surface">
    <div class="container-main">
      <p class="overline mb-3">Home Theater Design and Build</p>
      <h2 class="font-display text-h2 text-warm-white mb-6">
        Built Around Your Room. Designed for How You Watch.
      </h2>
      <p class="text-body-lg text-stone mb-12 max-w-2xl">
        Before we spec a single piece of equipment, we measure your room, assess the acoustics, and understand how you use the space. Then we design a system that sounds like it was built for that specific room — because it was.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h3 class="font-sans font-semibold text-h3 text-warm-white mb-5">Dedicated Theater Rooms</h3>
          <ul class="flex flex-col gap-3 mb-10">
            {[
              "4K and laser projection systems (Epson, Sony, BenQ, JVC)",
              "Fixed-frame and motorized projection screens",
              "Dolby Atmos 7.2.4 and 9.2.4 surround sound",
              "In-wall and in-ceiling speaker systems",
              "Custom tiered seating platforms",
              "LED bias and accent lighting control",
              "Acoustic treatment and room calibration",
              "Rack-mounted equipment with clean cable management",
              "Universal control systems (Control4, RTI)",
            ].map((item) => (
              <li class="flex items-start gap-3 text-body text-stone">
                <span class="text-gold mt-1 flex-shrink-0">&rarr;</span>
                {item}
              </li>
            ))}
          </ul>

          <h3 class="font-sans font-semibold text-h3 text-warm-white mb-5">Media Room Conversions</h3>
          <ul class="flex flex-col gap-3">
            {[
              "Large-format 4K displays (85 to 110 inch)",
              "Soundbars and 5.1 and 7.1 surround upgrades",
              "Hidden wire and in-wall power solutions",
              "Streaming and source device integration",
              "Existing room retrofits with minimal disruption",
            ].map((item) => (
              <li class="flex items-start gap-3 text-body text-stone">
                <span class="text-gold mt-1 flex-shrink-0">&rarr;</span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="flex flex-col gap-6">
          <div class="card p-7">
            <p class="overline mb-3">The KZ Difference</p>
            <h3 class="font-sans font-semibold text-h3 text-warm-white mb-4">The Same Team, Start to Finish.</h3>
            <p class="text-body text-stone mb-4">
              Every home theater we build is installed by Kelly, Billy, or Julian. We do not hand your project to a crew you have never met. Every system is calibrated by the person who designed it.
            </p>
            <p class="text-body text-stone">
              We have been doing this since 1997. We design around the problems that make theaters disappointing: rooms that echo, systems that feel unbalanced, equipment that will not integrate. Every decision starts with the room.
            </p>
          </div>

          <div class="card p-7">
            <p class="overline mb-3">New Construction</p>
            <h3 class="font-sans font-semibold text-h3 text-warm-white mb-4">Builder-Ready Pre-Wire</h3>
            <p class="text-body text-stone">
              We work with custom home builders throughout the Hill Country and San Antonio. Pre-wire, rough-in, trim-out, programming, and the homeowner walkthrough. Nine active builder relationships — the longest running since 2009.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ProjectsGrid
    projects={projects}
    overline="Recent Theater Builds"
    heading="Home Theater Projects in San Antonio and the Hill Country"
  />

  <TestimonialsSection featured={featured} secondary={secondary} />

  <section class="section bg-slate-surface">
    <div class="container-main">
      <p class="overline mb-3">Investment Guide</p>
      <h2 class="font-display text-h2 text-warm-white mb-6">
        What Does a Home Theater Cost in San Antonio?
      </h2>
      <p class="text-body-lg text-stone mb-10 max-w-2xl">
        We give you a detailed quote after seeing the space. Here is a realistic framework for budgeting.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            tier: "Media Room",
            range: "$5,000 to $12,000",
            desc: "Existing room, large 4K display, 5.1 surround or soundbar upgrade, streaming sources, hidden wiring. No construction required.",
          },
          {
            tier: "Mid-Tier Theater",
            range: "$15,000 to $40,000",
            desc: "4K projection, fixed-frame screen, 7.1 Dolby Atmos, in-wall speakers, tiered seating platform, acoustic treatment, full control system.",
          },
          {
            tier: "Premium Theater",
            range: "$40,000 to $80,000+",
            desc: "Laser projection, motorized screen, 9.2.4 Atmos, custom acoustics, motorized leather seating, full AV and lighting control.",
          },
        ].map(({ tier, range, desc }) => (
          <div class="card p-7">
            <p class="overline mb-2">{tier}</p>
            <p class="font-display text-h3 text-gold mb-4">{range}</p>
            <p class="text-body text-stone">{desc}</p>
          </div>
        ))}
      </div>
      <p class="text-body-sm text-ash mt-6">
        Prices are estimates for the San Antonio market. Final pricing depends on room size, materials, and equipment selection. We provide a written quote before any work begins.
      </p>
    </div>
  </section>

  <FAQAccordion
    heading="Home Theater Installation — Frequently Asked Questions"
    faqs={faqs}
  />

  <CTASection
    heading="Let us Design Your Home Theater."
    body="Book a free in-home consultation. We come to you, assess the space, and put together a system designed for that specific room. No pressure. No obligation."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
    bgImage="/images/projects/monty-theater/Home-Theater-Design-Build-Near-San-Antonio-Texas.jpeg.jpg"
  />

</BaseLayout>
