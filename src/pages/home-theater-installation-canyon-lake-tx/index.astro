---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServicesGrid from '../../components/sections/ServicesGrid.astro';
import ProjectsGrid from '../../components/sections/ProjectsGrid.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import CTASection from '../../components/sections/CTASection.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Home Theater Installation Canyon Lake",
  "provider": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "url": "https://kzaudioandvideo.com",
    "telephone": "+12109814098"
  },
  "areaServed": "Canyon Lake, TX",
  "description": "Custom home theater and AV installation in Canyon Lake TX.",
  "url": "https://kzaudioandvideo.com/home-theater-installation-canyon-lake-tx/"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Home Theater Installation Canyon Lake TX" }
  ]
};

const projects = [
  {
    title: 'Dedicated Home Theater — Canyon Lake TX',
    location: 'Canyon Lake, TX',
    service: 'Home Theater',
    description: 'Full theater room with custom leather power recliner seating, blue LED accent lighting, projection system, and in-wall surround sound.',
    imageSrc: '/images/projects/monty-theater/Canyon-Lake-Tesac-Home-Theater-Custom-Seating.jpeg.jpg',
    imageAlt: 'Custom home theater with leather recliners and blue LED lighting in Canyon Lake Texas',
  },
  {
    title: 'Dedicated Home Theater — San Antonio TX',
    location: 'San Antonio, TX',
    service: 'Home Theater',
    description: 'Epson projector, Screen Innovations fixed-frame screen, Martin Logan on-wall speakers, LED accent lighting.',
    imageSrc: '/images/projects/asanka-theater/theater-room-san-antonio-tx.jpg',
    imageAlt: 'Home theater installation in San Antonio Texas with projection screen and surround sound',
  },
];

const featured = {
  name: 'San Antonio Homeowner',
  location: 'San Antonio, TX',
  service: 'Home Theater Client — Nearly 10 Years',
  quote: "I've been a customer of KZ Audio for going on a decade. Kelly and crew have always been great to work with. They're honest and will recommend what actually works for your situation rather than upselling you on equipment you don't need.",
};
---

<BaseLayout
  title="Home Theater Installation Canyon Lake TX | KZ Audio & Video"
  description="Custom home theater and AV installation in Canyon Lake TX. In the audio business since 1997. Call (210) 981-4098."
  schema={[schema, breadcrumb]}
>

  <HeroSection
    overline="Home Theater Installation · Canyon Lake · Hill Country · Since 2001"
    heading="Home Theater Installation in Canyon Lake, TX"
    subhead="KZ Audio & Video designs and installs custom home theaters, whole-house audio, and outdoor AV systems in Canyon Lake and across the Hill Country. Canyon Lake, TX — Hill Country lake community northwest of San Antonio. We've completed multiple theater installs in Canyon Lake. In the audio business since 1997."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryCta="Or call: (210) 981-4098"
    secondaryHref="tel:2109814098"
    imageSrc="/images/projects/monty-theater/Canyon-Lake-Tesac-Home-Theater-Custom-Seating.jpeg.jpg"
    imageAlt="Custom home theater installation in Canyon Lake Texas Hill Country"
  />

  <TrustBar />

  <ServicesGrid
    intro="KZ Audio & Video serves Canyon Lake and the surrounding Hill Country. We design, install, and service custom home AV systems."
  />

  <ProjectsGrid
    projects={projects}
    overline="Recent Projects"
    heading="Home Theater Installs Near Canyon Lake"
  />

  <TestimonialsSection featured={featured} />

  <!-- Canyon Lake Local Context -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <p class="overline mb-3 reveal">About Canyon Lake</p>
      <h2 class="font-display text-h2 text-warm-white mb-8 reveal reveal-delay-1">
        We've Done This Drive Many Times
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-12">
        <div>
          <p class="text-body-lg text-stone mb-6 reveal reveal-delay-2">
            Canyon Lake is one of our most active Hill Country markets. The dedicated home theater project in our portfolio — custom leather power recliners, blue LED step lighting, in-wall Dolby surround sound — was built right here in Canyon Lake. We know the area, we know the drive, and we've worked in enough properties along the lake to understand what these homes need.
          </p>
          <p class="text-body text-stone reveal reveal-delay-3">
            Canyon Lake properties are a mix of primary residences, weekend retreats, and vacation homes — many with large covered outdoor spaces that are natural fits for outdoor AV. Whether it's a dedicated theater room, a whole-house audio system, or speakers on a lakeside patio, we've done it here. The consultation is always free, and we always come to you.
          </p>
        </div>
        <div class="flex flex-col gap-6">
          <div class="reveal reveal-delay-2">
            <h3 class="font-sans font-semibold text-warm-white mb-2">Proven Work in Canyon Lake</h3>
            <p class="text-body-sm text-stone">Our Canyon Lake theater build is one of our most-referenced projects. Full pre-wire, custom seating platform, projection system, and in-wall surround — completed start to finish by our team.</p>
          </div>
          <div class="reveal reveal-delay-3">
            <h3 class="font-sans font-semibold text-warm-white mb-2">One Team, Every Install</h3>
            <p class="text-body-sm text-stone">Kelly, Billy, and Julian do every install personally. The same crew who scoped your project shows up on install day.</p>
          </div>
          <div class="reveal reveal-delay-4">
            <h3 class="font-sans font-semibold text-warm-white mb-2">Free Consultation — We Drive to You</h3>
            <p class="text-body-sm text-stone">We make the drive to Canyon Lake for every consultation. See the space, understand the goals, give you a real quote. No charge, no pressure.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Get Started in Canyon Lake?"
    body="Book a free, no-pressure consultation. We'll come to your home in Canyon Lake and talk through what's possible."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>
