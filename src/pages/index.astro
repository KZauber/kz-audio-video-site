---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import TestimonialsSection from '../components/sections/TestimonialsSection.astro';
import ProjectsGrid from '../components/sections/ProjectsGrid.astro';
import CTASection from '../components/sections/CTASection.astro';

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "@id": "https://kzaudioandvideo.com",
  "name": "KZ Audio & Video",
  "description": "Custom home theater, whole-house audio, outdoor AV, and security camera installation in San Antonio TX and the Texas Hill Country. In the audio business since 1997.",
  "url": "https://kzaudioandvideo.com",
  "telephone": "+12109814098",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "San Antonio",
    "addressRegion": "TX",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 29.4241,
    "longitude": -98.4936
  },
  "areaServed": [
    "San Antonio", "Boerne", "Bulverde", "Canyon Lake",
    "Helotes", "Stone Oak", "Timberwood Park", "New Braunfels"
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
    "opens": "08:00",
    "closes": "17:00"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "19",
    "bestRating": "5"
  },
  "foundingDate": "2001",
  "slogan": "In the audio business since 1997. Home AV since 2001."
};

const featuredProjects = [
  {
    title: 'Dedicated Home Theater — Canyon Lake TX',
    location: 'Canyon Lake, TX',
    service: 'Home Theater',
    href: '/projects/canyon-lake-dedicated-home-theater/',
    description: 'Full dedicated theater room: custom leather power recliner seating on a raised platform, blue LED step lighting, projection screen, and in-wall Dolby surround sound. Built from pre-wire to programming.',
    imageSrc: '/images/projects/monty-theater/Canyon-Lake-Tesac-Home-Theater-Projection-Screen.jpeg.jpg',
    imageAlt: 'Custom home theater projection screen with blue LED lighting and leather seating in Canyon Lake Texas',
  },
  {
    title: 'Home Theater — Stone Oak San Antonio',
    location: 'Stone Oak, San Antonio, TX',
    service: 'Home Theater',
    href: '/projects/stone-oak-home-theater-epson-martin-logan/',
    description: 'Epson laser projector, Screen Innovations fixed-frame screen, Martin Logan on-wall speakers front and rear, custom LED lighting. Complete pre-wire through finished install.',
    imageSrc: '/images/projects/asanka-theater/theater-room-san-antonio-tx.jpg',
    imageAlt: 'Home theater installation in Stone Oak San Antonio Texas with projection screen and Martin Logan surround sound',
  },
  {
    title: 'Star Wars Home Theater — San Antonio TX',
    location: 'San Antonio, TX',
    service: 'Home Theater',
    href: '/projects/star-wars-home-theater-san-antonio/',
    description: 'Custom built-in entertainment wall with fixed-frame projection screen, JVC projector, and complete Dolby Atmos surround system. Designed around the client\'s collection — not a template build.',
    imageSrc: '/images/projects/davids-theater/home-theater-front-view.jpeg.jpg',
    imageAlt: 'Custom Star Wars themed home theater with projection screen and built-in display wall in San Antonio Texas',
  },
  {
    title: 'Samsung Frame TV on Marble Fireplace Wall',
    location: 'San Antonio, TX',
    service: 'TV Installation',
    href: '/projects/samsung-frame-tv-marble-fireplace-san-antonio/',
    description: 'Samsung Frame TV flush-mounted on a custom marble fireplace wall with Sonos Arc soundbar. Zero visible wiring. Displays fine art when not in use.',
    imageSrc: '/images/projects/flat-tvs/samsung-frame-tv-marble-wall-san-antonio.jpg',
    imageAlt: 'Samsung Frame TV installed on marble fireplace wall in San Antonio Texas custom home',
  },
  {
    title: 'Outdoor Patio Projector — San Antonio TX',
    location: 'San Antonio, TX',
    service: 'Outdoor AV',
    href: '/projects/hill-country-outdoor-av-pool/',
    description: 'Projector ceiling-mounted under a limestone arch on a covered patio overlooking the pool. Rock speakers throughout the yard for whole-property audio.',
    imageSrc: '/images/projects/outdoor-av/san-antonio-projector-pool.jpg',
    imageAlt: 'Outdoor projector and pool area with rock speakers installed by KZ Audio and Video in San Antonio TX',
  },
  {
    title: 'Home Theater — Stone Oak, San Antonio TX',
    location: 'Stone Oak, San Antonio, TX',
    service: 'Home Theater',
    href: '/projects/stone-oak-new-construction-home-theater/',
    description: 'New construction dedicated theater room. Full pre-wire, Epson projector, Martin Logan center channel and subwoofer, in-wall surround speakers, and custom seating platform.',
    imageSrc: '/images/projects/young-theater/young-theater-san-antonio-tx.jpg',
    imageAlt: 'Home theater installation in Stone Oak San Antonio with projection system and surround sound',
  },
];

const ericTurner = {
  name: 'San Antonio Homeowner',
  location: 'San Antonio, TX',
  service: 'Home Theater Client — Nearly 10 Years',
  quote: "I've been a customer of KZ Audio for going on a decade. Kelly and crew have always been great to work with. They're honest and will recommend what actually works for your situation rather than upselling you on equipment you don't need. I've never had a bad experience with them and would absolutely recommend them to anyone looking for AV services.",
};

const secondaryReviews = [
  {
    name: 'Canyon Lake Homeowner',
    location: 'Canyon Lake, TX',
    service: 'Home Theater',
    quote: 'Billy, Julien and Kelly did an outstanding job on my home theater build. From start to finish they were professional, knowledgeable, and easy to work with. The theater came out better than I had hoped.',
  },
  {
    name: 'San Antonio Homeowner',
    location: 'San Antonio, TX',
    service: 'Home Theater',
    quote: 'KZ Audio and Video did a great job installing our home theater system. They were professional, on time, and their attention to detail was outstanding.',
  },
];
---

<BaseLayout
  title="Home Theater Installation San Antonio TX | KZ Audio & Video"
  description="KZ Audio & Video installs custom home theaters, whole-house audio, and outdoor AV systems in San Antonio and the Hill Country. In the audio business since 1997. No subcontractors. Call (210) 981-4098."
  schema={localBusiness}
>

  <HeroSection
    overline="San Antonio · Boerne · Canyon Lake · Hill Country · Since 2001"
    heading="Home Theater Installation San Antonio TX"
    subhead="KZ Audio & Video builds dedicated theaters, whole-house audio, and outdoor AV for homeowners and custom builders across San Antonio and the Texas Hill Country. In the business since 1997. No subcontractors — ever."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryCta="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
    imageSrc="/images/monty-theater-hero.jpg"
    imageAlt="Custom home theater with projection screen and blue LED lighting installed by KZ Audio and Video in Canyon Lake Texas"
    videoSrc="/videos/kz-hero.mp4"
  />

  <TrustBar />

  <!-- ── HOW IT WORKS ─────────────────────────────────────────────── -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <p class="overline mb-3 reveal">Simple Process</p>
      <h2 class="font-display text-h2 text-warm-white mb-4 reveal reveal-delay-1">
        From First Call to Finished Theater
      </h2>
      <p class="text-body-lg text-stone mb-16 max-w-2xl reveal reveal-delay-2">
        Three steps. No runaround. No subcontractors handed off mid-project.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
        <!-- Connecting line (desktop only) -->
        <div class="hidden md:block absolute top-10 left-[calc(16.67%+1rem)] right-[calc(16.67%+1rem)] h-px" style="background:linear-gradient(90deg, transparent 0%, rgba(201,168,76,0.4) 20%, rgba(201,168,76,0.4) 80%, transparent 100%);" aria-hidden="true"></div>

        <!-- Step 1 -->
        <div class="flex flex-col items-start gap-5 reveal reveal-delay-1">
          <div class="flex items-center justify-center w-20 h-20 rounded-full border border-gold/40 bg-gold/5 flex-shrink-0 relative">
            <span class="font-display font-bold text-gold" style="font-size:1.75rem;">01</span>
          </div>
          <div>
            <h3 class="font-sans font-semibold text-h4 text-warm-white mb-3">Free In-Home Consultation</h3>
            <p class="text-body-sm text-stone leading-relaxed">
              We come to you. Walk the space. Tell you exactly what's possible in your room, at your budget. No pressure, no sales pitch — just honest answers.
            </p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-start gap-5 reveal reveal-delay-2">
          <div class="flex items-center justify-center w-20 h-20 rounded-full border border-gold/40 bg-gold/5 flex-shrink-0">
            <span class="font-display font-bold text-gold" style="font-size:1.75rem;">02</span>
          </div>
          <div>
            <h3 class="font-sans font-semibold text-h4 text-warm-white mb-3">Custom Design & Equipment</h3>
            <p class="text-body-sm text-stone leading-relaxed">
              We spec the system around your room — not a product package. Right projector, right speakers, right seating layout. Everything chosen for your specific space.
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-start gap-5 reveal reveal-delay-3">
          <div class="flex items-center justify-center w-20 h-20 rounded-full border border-gold/40 bg-gold/5 flex-shrink-0">
            <span class="font-display font-bold text-gold" style="font-size:1.75rem;">03</span>
          </div>
          <div>
            <h3 class="font-sans font-semibold text-h4 text-warm-white mb-3">Clean Install. Done Right.</h3>
            <p class="text-body-sm text-stone leading-relaxed">
              KZ crew does the install — not a subcontractor. We stay until the system is calibrated, you understand it, and everything works the way it should.
            </p>
          </div>
        </div>
      </div>

      <div class="mt-14 flex flex-col sm:flex-row gap-4 reveal reveal-delay-4">
        <a href="/contact-kz-audio-video-san-antonio-tx/" class="btn-primary gold-shimmer">Book Your Free Consultation</a>
        <a href="tel:2109814098" class="btn-ghost">Call (210) 981-4098</a>
      </div>
    </div>
  </section>

  <ServicesGrid
    intro="From a dedicated home theater to speakers on the back patio, KZ handles the design, the installation, and everything after."
  />

  <TestimonialsSection
    featured={ericTurner}
    secondary={secondaryReviews}
  />

  <ProjectsGrid
    projects={featuredProjects}
    overline="Recent Work"
    heading="Custom Home Theater and AV Projects"
  />

  <!-- Builder callout -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="overline mb-3">For Custom Home Builders</p>
          <h2 class="font-display text-h2 text-warm-white mb-6">
            Your Low Voltage and AV Partner for Every Build
          </h2>
          <p class="text-body-lg text-stone mb-4">
            KZ Audio & Video works with custom home builders across San Antonio and the Hill Country. Nine active builder relationships. The longest started in 2009.
          </p>
          <p class="text-body text-stone mb-8">
            We handle pre-wire scheduling, rough-in, trim-out, system programming, and the homeowner walkthrough. You make the introduction. We handle everything after — including the callbacks.
          </p>
          <a href="/av-partner-for-home-builders-san-antonio/" class="btn-ghost">
            Learn About Our Builder Program
          </a>
        </div>
        <div class="flex flex-col gap-4">
          <blockquote class="card p-6 border-l-4 border-gold rounded-l-none">
            <p class="text-body text-warm-white italic mb-3">"I have been working with Kelly for 16 years. He and his team are true professionals. They show up on time, do quality work, and handle our homeowners with the utmost professionalism."</p>
            <footer class="text-caption text-stone uppercase tracking-widest">Builder Partner &middot; 16 Years</footer>
          </blockquote>
          <blockquote class="card p-6 border-l-4 border-gold rounded-l-none">
            <p class="text-body text-warm-white italic mb-3">"KZ Audio and Video is our go-to for all AV and low voltage work on our custom homes. Kelly and his team are reliable, professional, and do excellent work."</p>
            <footer class="text-caption text-stone uppercase tracking-widest">Active Builder Partner</footer>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- About teaser -->
  <section class="section bg-slate-surface">
    <div class="container-main">
      <p class="overline mb-3">About KZ Audio & Video</p>
      <h2 class="font-display text-h2 text-warm-white mb-6">In the Audio Business Since 1997</h2>
      <p class="text-body-lg text-stone mb-4 max-w-2xl">
        Kelly Zauber started Audio Outlet in 1997 with his best friend. Moved into automotive audio in 1999. Started doing home AV in 2001 and never looked back.
      </p>
      <p class="text-body text-stone mb-8 max-w-2xl">
        Today KZ Audio & Video is Kelly, Billy, and Julian. No subcontractors. Every install is done by someone on this team. Every system is designed around the specific room, the specific client, and how they actually live.
      </p>
      <a href="/about-kz-audio-video/" class="btn-text">More about the team &rarr;</a>
    </div>
  </section>

  <CTASection />

</BaseLayout>
