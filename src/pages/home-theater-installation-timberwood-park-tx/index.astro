---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServicesGrid from '../../components/sections/ServicesGrid.astro';
import ProjectsGrid from '../../components/sections/ProjectsGrid.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import CTASection from '../../components/sections/CTASection.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Home Theater Installation Timberwood Park",
  "provider": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "url": "https://kzaudioandvideo.com",
    "telephone": "+12109814098"
  },
  "areaServed": "Timberwood Park, TX",
  "description": "Custom home theater and AV installation in Timberwood Park TX.",
  "url": "https://kzaudioandvideo.com/home-theater-installation-timberwood-park-tx/"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Home Theater Installation Timberwood Park TX" }
  ]
};

const projects = [
  {
    title: 'Dedicated Home Theater — Canyon Lake TX',
    location: 'Canyon Lake, TX',
    service: 'Home Theater',
    description: 'Full theater room with custom leather power recliner seating, blue LED accent lighting, projection system, and in-wall surround sound.',
    imageSrc: '/images/projects/monty-theater/Canyon-Lake-Tesac-Home-Theater-Custom-Seating.jpeg.jpg',
    imageAlt: 'Custom home theater with leather recliners and blue LED lighting in Canyon Lake Texas',
  },
  {
    title: 'Dedicated Home Theater — San Antonio TX',
    location: 'San Antonio, TX',
    service: 'Home Theater',
    description: 'Epson projector, Screen Innovations fixed-frame screen, Martin Logan on-wall speakers, LED accent lighting.',
    imageSrc: '/images/projects/asanka-theater/theater-room-san-antonio-tx.jpg',
    imageAlt: 'Home theater installation in San Antonio Texas with projection screen and surround sound',
  },
];

const featured = {
  name: 'San Antonio Homeowner',
  location: 'San Antonio, TX',
  service: 'Home Theater Client — Nearly 10 Years',
  quote: "I've been a customer of KZ Audio for going on a decade. Kelly and crew have always been great to work with. They're honest and will recommend what actually works for your situation rather than upselling you on equipment you don't need.",
};
---

<BaseLayout
  title="Home Theater Installation Timberwood Park TX | KZ Audio & Video"
  description="Custom home theater and AV installation in Timberwood Park TX. In the audio business since 1997. Call (210) 981-4098."
  schema={[schema, breadcrumb]}
>

  <HeroSection
    overline="Home Theater Installation · Timberwood Park · North San Antonio · Since 2001"
    heading="Home Theater Installation in Timberwood Park, TX"
    subhead="KZ Audio & Video designs and installs custom home theaters, whole-house audio, and outdoor AV systems in Timberwood Park and across the North San Antonio. Timberwood Park — a community north of San Antonio in the Hill Country near Helotes and Boerne. In the audio business since 1997."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryCta="Or call: (210) 981-4098"
    secondaryHref="tel:2109814098"
    imageSrc="/images/projects/monty-theater/Home-Theater-Design-Build-Near-San-Antonio-Texas.jpeg.jpg"
    imageAlt="Custom home theater installation in Timberwood Park Texas near San Antonio"
  />

  <TrustBar />

  <ServicesGrid
    intro="KZ Audio & Video serves Timberwood Park and the surrounding North San Antonio. We design, install, and service custom home AV systems."
  />

  <ProjectsGrid
    projects={projects}
    overline="Recent Projects"
    heading="Home Theater Installs Near Timberwood Park"
  />

  <TestimonialsSection featured={featured} />

  <!-- Timberwood Park Local Context -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <p class="overline mb-3 reveal">About Timberwood Park</p>
      <h2 class="font-display text-h2 text-warm-white mb-8 reveal reveal-delay-1">
        Large Lots, Established Homes, and Room to Do It Right
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-12">
        <div>
          <p class="text-body-lg text-stone mb-6 reveal reveal-delay-2">
            Timberwood Park is an established unincorporated community in north Bexar County — large wooded lots, custom homes built over several decades, and a character that sets it apart from the newer master-planned developments along US-281. Most properties here have been owned for years and are being upgraded rather than built from scratch, which is a different kind of project than new construction.
          </p>
          <p class="text-body text-stone reveal reveal-delay-3">
            Upgrade projects in Timberwood Park often involve working with existing room layouts, running wire through finished walls, and integrating modern AV equipment into homes that weren't originally pre-wired for it. That's the kind of work that separates experienced installers from people who only do new construction. We do both — and we do them cleanly.
          </p>
        </div>
        <div class="flex flex-col gap-6">
          <div class="reveal reveal-delay-2">
            <h3 class="font-sans font-semibold text-warm-white mb-2">Retrofit & Upgrade Specialists</h3>
            <p class="text-body-sm text-stone">Not every home in Timberwood Park was pre-wired for AV. We run wire through finished walls, work around existing construction, and deliver a clean install in homes built before the modern AV era.</p>
          </div>
          <div class="reveal reveal-delay-3">
            <h3 class="font-sans font-semibold text-warm-white mb-2">One Team, Every Install</h3>
            <p class="text-body-sm text-stone">Kelly, Billy, and Julian do every install. Retrofit work especially requires experience. The same people who assess your home do the work.</p>
          </div>
          <div class="reveal reveal-delay-4">
            <h3 class="font-sans font-semibold text-warm-white mb-2">Free Consultation in Timberwood Park</h3>
            <p class="text-body-sm text-stone">We come to your home, assess the space and existing construction, and give you a real quote. No charge, no obligation — and no surprises on install day.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Get Started in Timberwood Park?"
    body="Book a free, no-pressure consultation. We'll come to your home in Timberwood Park and talk through what's possible."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>
