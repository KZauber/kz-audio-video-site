---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/sections/TrustBar.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact KZ Audio & Video",
  "url": "https://kzaudioandvideo.com/contact-kz-audio-video-san-antonio-tx/",
  "mainEntity": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "telephone": "+12109814098",
    "email": "kelly@kzaudioandvideo.com",
    "areaServed": "San Antonio, TX"
  }
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Contact KZ Audio & Video" }
  ]
};
---

<BaseLayout
  title="Contact KZ Audio & Video | San Antonio TX Home Theater Installation"
  description="Contact KZ Audio & Video to book a free home theater or AV consultation in San Antonio TX. Call (210) 981-4098 or fill out the form. We serve San Antonio and the Texas Hill Country."
  schema={[schema, breadcrumb]}
>

  <!-- Hero -->
  <section class="section bg-charcoal pt-32">
    <div class="container-main">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Left: copy + contact details -->
        <div>
          <p class="overline mb-3">Contact</p>
          <h1 class="font-display text-h1 text-warm-white mb-6">
            Book a Free Consultation
          </h1>
          <p class="text-body-lg text-stone mb-8">
            We come to you. Tell us about your project — what you're looking for, the space, and the timeline. We'll schedule a time to meet at your home or job site. No obligation, no pressure.
          </p>

          <!-- Phone -->
          <a
            href="tel:2109814098"
            class="flex items-center gap-4 group mb-6"
          >
            <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 group-hover:bg-gold/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.4 2 2 0 0 1 3.6 2.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.08 6.08l.97-.97a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <p class="text-caption text-stone uppercase tracking-widest mb-0.5">Phone</p>
              <p class="font-sans font-semibold text-h4 text-warm-white group-hover:text-gold transition-colors">(210) 981-4098</p>
            </div>
          </a>

          <!-- Service Areas -->
          <div class="mb-8">
            <p class="text-caption text-stone uppercase tracking-widest mb-3">Service Areas</p>
            <p class="text-body text-stone">
              San Antonio · Boerne · Bulverde · Canyon Lake · Helotes · Stone Oak · Timberwood Park · New Braunfels · and surrounding Texas Hill Country
            </p>
          </div>

          <!-- Hours -->
          <div>
            <p class="text-caption text-stone uppercase tracking-widest mb-3">Hours</p>
            <p class="text-body text-stone">Monday – Friday, 8am – 5pm</p>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class="card p-8">
          <h2 class="font-sans font-semibold text-h3 text-warm-white mb-6">Tell Us About Your Project</h2>
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/contact-kz-audio-video-san-antonio-tx/thank-you/"
            class="flex flex-col gap-5"
          >
            <!-- Honeypot -->
            <p class="hidden">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>
            <input type="hidden" name="form-name" value="contact" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="flex flex-col gap-2">
                <label for="name" class="text-caption text-stone uppercase tracking-widest">Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="bg-graphite border border-smoke rounded-sm px-4 py-3 text-warm-white text-body
                         placeholder-stone/50 focus:outline-none focus:border-gold transition-colors"
                  placeholder="Your name"
                />
              </div>
              <div class="flex flex-col gap-2">
                <label for="phone" class="text-caption text-stone uppercase tracking-widest">Phone *</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="bg-graphite border border-smoke rounded-sm px-4 py-3 text-warm-white text-body
                         placeholder-stone/50 focus:outline-none focus:border-gold transition-colors"
                  placeholder="(210) 555-0000"
                />
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label for="email" class="text-caption text-stone uppercase tracking-widest">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                class="bg-graphite border border-smoke rounded-sm px-4 py-3 text-warm-white text-body
                       placeholder-stone/50 focus:outline-none focus:border-gold transition-colors"
                placeholder="your@email.com"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label for="service" class="text-caption text-stone uppercase tracking-widest">What Are You Looking For?</label>
              <select
                id="service"
                name="service"
                class="bg-graphite border border-smoke rounded-sm px-4 py-3 text-warm-white text-body
                       focus:outline-none focus:border-gold transition-colors appearance-none"
              >
                <option value="" class="text-stone">Select a service...</option>
                <option value="home-theater">Home Theater</option>
                <option value="whole-house-audio">Whole House Audio</option>
                <option value="outdoor-av">Outdoor Audio & Video</option>
                <option value="surround-sound">Surround Sound</option>
                <option value="security-cameras">Security Cameras</option>
                <option value="av-repair">AV Repair / Service</option>
                <option value="new-construction">New Construction / Builder</option>
                <option value="not-sure">Not Sure Yet</option>
              </select>
            </div>

            <div class="flex flex-col gap-2">
              <label for="message" class="text-caption text-stone uppercase tracking-widest">Tell Us About Your Project</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                class="bg-graphite border border-smoke rounded-sm px-4 py-3 text-warm-white text-body
                       placeholder-stone/50 focus:outline-none focus:border-gold transition-colors resize-none"
                placeholder="Room size, what you're envisioning, timeline, budget range — anything that helps us understand the project."
              ></textarea>
            </div>

            <button
              type="submit"
              class="btn-primary w-full justify-center"
            >
              Send Message
            </button>

            <p class="text-caption text-stone text-center">
              Or call us directly: <a href="tel:2109814098" class="text-gold hover:text-gold-light">(210) 981-4098</a>
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <TrustBar />

</BaseLayout>
