---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServicesGrid from '../../components/sections/ServicesGrid.astro';
import ProjectsGrid from '../../components/sections/ProjectsGrid.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import CTASection from '../../components/sections/CTASection.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Home Theater Installation Bulverde",
  "provider": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "url": "https://kzaudioandvideo.com",
    "telephone": "+12109814098"
  },
  "areaServed": "Bulverde, TX",
  "description": "Custom home theater and AV installation in Bulverde TX and the North San Antonio Hill Country.",
  "url": "https://kzaudioandvideo.com/home-theater-installation-bulverde-tx/"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Home Theater Installation Bulverde TX" }
  ]
};

const projects = [
  {
    title: 'Dedicated Home Theater — Canyon Lake TX',
    location: 'Canyon Lake, TX',
    service: 'Home Theater',
    description: 'Full theater room with custom leather power recliner seating, blue LED accent lighting, projection system, and in-wall surround sound.',
    imageSrc: '/images/projects/monty-theater/Canyon-Lake-Tesac-Home-Theater-Custom-Seating.jpeg.jpg',
    imageAlt: 'Custom home theater with leather recliners and blue LED lighting in Canyon Lake Texas',
  },
  {
    title: 'Dedicated Home Theater — San Antonio TX',
    location: 'San Antonio, TX',
    service: 'Home Theater',
    description: 'Epson projector, Screen Innovations fixed-frame screen, Martin Logan on-wall speakers, LED accent lighting.',
    imageSrc: '/images/projects/asanka-theater/theater-room-san-antonio-tx.jpg',
    imageAlt: 'Home theater installation in San Antonio Texas with projection screen and surround sound',
  },
];

const featured = {
  name: 'San Antonio Homeowner',
  location: 'San Antonio, TX',
  service: 'Home Theater Client — Nearly 10 Years',
  quote: "I've been a customer of KZ Audio for going on a decade. Kelly and crew have always been great to work with. They're honest and will recommend what actually works for your situation rather than upselling you on equipment you don't need.",
};
---

<BaseLayout
  title="Home Theater Installation Bulverde TX | KZ Audio & Video"
  description="Custom home theater and AV installation in Bulverde TX and the North San Antonio Hill Country. No subcontractors. In the audio business since 1997. Call (210) 981-4098."
  schema={[schema, breadcrumb]}
>

  <HeroSection
    overline="Home Theater Installation · Bulverde · Hill Country · Since 2001"
    heading="Home Theater Installation in Bulverde, TX"
    subhead="KZ Audio & Video designs and installs custom home theaters, whole-house audio, and outdoor AV systems in Bulverde and across the Hill Country. Bulverde, TX — a fast-growing Hill Country community north of San Antonio. In the audio business since 1997. No subcontractors — ever."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryCta="Or call: (210) 981-4098"
    secondaryHref="tel:2109814098"
    imageSrc="/images/projects/monty-theater/Home-Theater-Design-Build-Near-San-Antonio-Texas.jpeg.jpg"
    imageAlt="Custom home theater installation in Bulverde Texas near San Antonio"
  />

  <TrustBar />

  <ServicesGrid
    intro="KZ Audio & Video serves Bulverde and the surrounding Hill Country. We design, install, and service custom home AV systems — no subcontractors, no third-party labor."
  />

  <ProjectsGrid
    projects={projects}
    overline="Recent Projects"
    heading="Home Theater Installs Near Bulverde"
  />

  <TestimonialsSection featured={featured} />

  <!-- Bulverde Local Context -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <p class="overline mb-3 reveal">About Bulverde</p>
      <h2 class="font-display text-h2 text-warm-white mb-8 reveal reveal-delay-1">
        Why Bulverde Homeowners Call KZ
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-12">
        <div>
          <p class="text-body-lg text-stone mb-6 reveal reveal-delay-2">
            Bulverde sits along the US-281 corridor in north Bexar and Comal County — one of the fastest-growing residential areas in Texas. The large-lot custom homes going up in communities throughout the area are exactly what we're used to working in: dedicated rooms with real acoustic potential, outdoor spaces built for entertainment, and homeowners who want the system done right the first time.
          </p>
          <p class="text-body text-stone reveal reveal-delay-3">
            We serve both new construction in Bulverde's growing communities and existing homes where homeowners are upgrading older AV systems to something that actually performs. Either way, the process starts with a free consultation at your home — we don't quote sight unseen.
          </p>
        </div>
        <div class="flex flex-col gap-6">
          <div class="reveal reveal-delay-2">
            <h3 class="font-sans font-semibold text-warm-white mb-2">No Subcontractors — Ever</h3>
            <p class="text-body-sm text-stone">Every install in Bulverde is done by Kelly, Billy, or Julian. Not a third-party crew. The team that designed your system installs it and stands behind it.</p>
          </div>
          <div class="reveal reveal-delay-3">
            <h3 class="font-sans font-semibold text-warm-white mb-2">In the Audio Business Since 1997</h3>
            <p class="text-body-sm text-stone">Kelly has been in audio since 1997 and home AV since 2001. We've worked in a lot of north Bexar County rooms over the years — enough to know how the acoustics differ between a dedicated theater and a great room conversion.</p>
          </div>
          <div class="reveal reveal-delay-4">
            <h3 class="font-sans font-semibold text-warm-white mb-2">Free Consultation in Bulverde</h3>
            <p class="text-body-sm text-stone">We drive to Bulverde. Walk the room with you. Tell you what's possible and what it costs. No charge, no obligation — just honest answers about your space.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Get Started in Bulverde?"
    body="Book a free, no-pressure consultation. We'll come to your home in Bulverde and talk through what's possible."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>
