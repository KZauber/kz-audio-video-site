---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServicesGrid from '../../components/sections/ServicesGrid.astro';
import ProjectsGrid from '../../components/sections/ProjectsGrid.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import CTASection from '../../components/sections/CTASection.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Home Theater Installation Helotes",
  "provider": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "url": "https://kzaudioandvideo.com",
    "telephone": "+12109814098"
  },
  "areaServed": "Helotes, TX",
  "description": "Custom home theater and AV installation in Helotes TX and northwest San Antonio.",
  "url": "https://kzaudioandvideo.com/home-theater-installation-helotes-tx/"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Home Theater Installation Helotes TX" }
  ]
};

const projects = [
  {
    title: 'Dedicated Home Theater — Canyon Lake TX',
    location: 'Canyon Lake, TX',
    service: 'Home Theater',
    description: 'Full theater room with custom leather power recliner seating, blue LED accent lighting, projection system, and in-wall surround sound.',
    imageSrc: '/images/projects/monty-theater/Canyon-Lake-Tesac-Home-Theater-Custom-Seating.jpeg.jpg',
    imageAlt: 'Custom home theater with leather recliners and blue LED lighting in Canyon Lake Texas',
  },
  {
    title: 'Dedicated Home Theater — San Antonio TX',
    location: 'San Antonio, TX',
    service: 'Home Theater',
    description: 'Epson projector, Screen Innovations fixed-frame screen, Martin Logan on-wall speakers, LED accent lighting.',
    imageSrc: '/images/projects/asanka-theater/theater-room-san-antonio-tx.jpg',
    imageAlt: 'Home theater installation in San Antonio Texas with projection screen and surround sound',
  },
];

const featured = {
  name: 'San Antonio Homeowner',
  location: 'San Antonio, TX',
  service: 'Home Theater Client — Nearly 10 Years',
  quote: "I've been a customer of KZ Audio for going on a decade. Kelly and crew have always been great to work with. They're honest and will recommend what actually works for your situation rather than upselling you on equipment you don't need.",
};
---

<BaseLayout
  title="Home Theater Installation Helotes TX | KZ Audio & Video"
  description="Custom home theater and AV installation in Helotes TX and northwest San Antonio. In the audio business since 1997. Call (210) 981-4098."
  schema={[schema, breadcrumb]}
>

  <HeroSection
    overline="Home Theater Installation · Helotes · Northwest San Antonio · Since 2001"
    heading="Home Theater Installation in Helotes, TX"
    subhead="KZ Audio & Video designs and installs custom home theaters, whole-house audio, and outdoor AV systems in Helotes and across the Northwest San Antonio. Helotes, TX — a community at the edge of San Antonio's northwest growth corridor. In the audio business since 1997."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryCta="Or call: (210) 981-4098"
    secondaryHref="tel:2109814098"
    imageSrc="/images/projects/asanka-theater/theater-room-san-antonio-tx.jpg"
    imageAlt="Custom home theater installation in Helotes Texas near San Antonio"
  />

  <TrustBar />

  <ServicesGrid
    intro="KZ Audio & Video serves Helotes and the surrounding Northwest San Antonio. We design, install, and service custom home AV systems."
  />

  <ProjectsGrid
    projects={projects}
    overline="Recent Projects"
    heading="Home Theater Installs Near Helotes"
  />

  <TestimonialsSection featured={featured} />

  <!-- Helotes Local Context -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <p class="overline mb-3 reveal">About Helotes</p>
      <h2 class="font-display text-h2 text-warm-white mb-8 reveal reveal-delay-1">
        Northwest San Antonio's Best-Kept Secret for Custom Homes
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-12">
        <div>
          <p class="text-body-lg text-stone mb-6 reveal reveal-delay-2">
            Helotes sits right at the edge of San Antonio's northwest corridor — close enough to the city to be convenient, far enough out for large lots and Hill Country character. It's a community where established custom neighborhoods sit alongside newer construction, and the homes tend to have the room layouts that dedicated theater builds are designed for.
          </p>
          <p class="text-body text-stone reveal reveal-delay-3">
            We've done a lot of work in the northwest quadrant over the years — Helotes, Leon Valley, the communities along Culebra and Bandera Road — and Helotes consistently has some of the most serious custom home buyers we meet. These homeowners know what they want and want it done right. That's exactly how we work.
          </p>
        </div>
        <div class="flex flex-col gap-6">
          <div class="reveal reveal-delay-2">
            <h3 class="font-sans font-semibold text-warm-white mb-2">One Team, Every Install</h3>
            <p class="text-body-sm text-stone">Every Helotes install is done by Kelly, Billy, or Julian. You deal with the same people from the first call through the final walkthrough.</p>
          </div>
          <div class="reveal reveal-delay-3">
            <h3 class="font-sans font-semibold text-warm-white mb-2">Northwest SA Is Our Backyard</h3>
            <p class="text-body-sm text-stone">We're based in San Antonio and do a significant share of our work on the northwest side. Helotes is not a long-drive market for us — it's a regular stop, and we're there often.</p>
          </div>
          <div class="reveal reveal-delay-4">
            <h3 class="font-sans font-semibold text-warm-white mb-2">Free Consultation — Always</h3>
            <p class="text-body-sm text-stone">We come to your Helotes home, look at the space, and give you a straight answer about what's possible and what it costs. No charge, no obligation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Get Started in Helotes?"
    body="Book a free, no-pressure consultation. We'll come to your home in Helotes and talk through what's possible."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>
