<BaseLayout
  title="Home Theater & AV FAQ San Antonio TX | KZ Audio & Video"
  description="Answers to common questions about home theater installation, whole house audio, and outdoor AV in San Antonio TX. KZ Audio & Video — (210) 981-4098."
  schema={[faqPageSchema, breadcrumb]}
>

  <section class="section bg-charcoal pt-32">
    <div class="container-content text-center">
      <p class="overline mb-4">KZ Audio & Video · San Antonio TX · Since 1997</p>
      <h1 class="font-display text-h1 text-warm-white mb-6">
        Home Theater & AV — Frequently Asked Questions
      </h1>
      <p class="text-body-lg text-stone max-w-2xl mx-auto">
        Answers to the questions we hear most — about home theater installation, whole house audio, and outdoor AV in San Antonio and the Texas Hill Country. Can't find what you need? Call us at <a href="tel:2109814098" class="text-gold hover:underline">(210) 981-4098</a>.
      </p>
    </div>
  </section>

  <TrustBar />

  <FAQAccordion
    heading="Home Theater — Frequently Asked Questions"
    faqs={homeTheaterFaqs}
  />

  <FAQAccordion
    heading="Whole House Audio — Frequently Asked Questions"
    faqs={wholeHouseAudioFaqs}
  />

  <FAQAccordion
    heading="Outdoor Audio & Video — Frequently Asked Questions"
    faqs={outdoorAVFaqs}
  />

  <FAQAccordion
    heading="General — Process, Timeline & Consultations"
    faqs={generalFaqs}
  />

  <CTASection
    heading="Still Have Questions? Let's Talk."
    body="Book a free in-home consultation. We come to you, assess the space, and answer every question you have about your project. No pressure. No obligation."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>
