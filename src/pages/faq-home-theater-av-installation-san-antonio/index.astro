---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import CTASection from '../../components/sections/CTASection.astro';

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "FAQ — Home Theater & AV Installation San Antonio" }
  ]
};

const faqCategories = [
  {
    category: 'Home Theater Installation',
    faqs: [
      {
        question: 'How much does a home theater installation cost in San Antonio?',
        answer: 'Most dedicated home theater projects range from $15,000 to $80,000 depending on room size, equipment tier, seating, and acoustic treatment. A media room conversion (existing space, no construction) typically starts around $8,000–$15,000. We provide detailed, itemized quotes at no charge.',
      },
      {
        question: 'How long does a home theater installation take?',
        answer: 'A media room in an existing finished space typically takes one to three days. A full dedicated theater — pre-wire, construction coordination, trim-out, and calibration — is usually spread across multiple visits over a few weeks, working around the construction timeline.',
      },
      {
        question: 'What projector brands do you install?',
        answer: 'We work with Epson, JVC, Sony, and BenQ — matched to the room\'s throw distance, ambient light conditions, and resolution goals. We also install Screen Innovations, Elite Screens, and Stewart Filmscreen fixed-frame, motorized, and acoustically transparent screens.',
      },
      {
        question: 'Do you install surround sound for living rooms (not just dedicated theaters)?',
        answer: 'Yes. Living room and media room surround sound installs are a significant part of what we do. Whether it\'s a 5.1 system in a living room, a sound bar + sub + surrounds setup, or a full Dolby Atmos configuration — we design it to the room.',
      },
    ],
  },
  {
    category: 'Working With KZ Audio & Video',
    faqs: [
      {
        question: 'Do you use subcontractors?',
        answer: 'Never. Every job is done by Kelly, Billy, or Julian — the three people on this team. We don\'t bring in outside labor. That\'s how we\'ve operated since 2001.',
      },
      {
        question: 'How do I book a consultation?',
        answer: 'Fill out the contact form on this site, call us at (210) 981-4098, or text us. We\'ll schedule a time to come to your home. The consultation is free, with no obligation.',
      },
      {
        question: 'Do you do in-home estimates?',
        answer: 'Yes. We come to you. Most AV and home theater systems need to be seen in context — room dimensions, wall construction, ceiling height, existing equipment — to quote accurately. We don\'t give estimates over the phone without seeing the space.',
      },
      {
        question: 'What areas do you serve?',
        answer: 'We serve San Antonio, Boerne, Bulverde, Canyon Lake, Helotes, Stone Oak, Timberwood Park, New Braunfels, and surrounding areas in the Texas Hill Country.',
      },
    ],
  },
  {
    category: 'New Construction & Builders',
    faqs: [
      {
        question: 'Do you work on new construction homes?',
        answer: 'Yes — new construction is a significant part of what we do. We work with custom home builders on pre-wire, rough-in, trim-out, programming, and homeowner walkthroughs. We also work directly with homeowners building custom homes.',
      },
      {
        question: 'I\'m a custom home builder. How does your builder program work?',
        answer: 'You make the introduction to your homeowner. We handle everything after — design meeting, pre-wire scheduling, rough-in, trim-out, programming, calibration, and the homeowner walkthrough. Post-move-in questions come to us, not you. We currently have nine active builder relationships. The longest started in 2009.',
      },
      {
        question: 'Can you coordinate with my construction schedule?',
        answer: 'Yes. We work with your site supervisor and schedule pre-wire around your framing and rough-in windows. We\'re familiar with how custom home builds run in San Antonio and the Hill Country.',
      },
    ],
  },
  {
    category: 'AV Repair & Service',
    faqs: [
      {
        question: 'Do you work on systems you didn\'t install?',
        answer: 'Yes. We service and repair AV systems regardless of who installed them. We diagnose the problem, tell you what it takes to fix it, and give you an honest assessment of whether it\'s worth fixing.',
      },
      {
        question: 'My home theater was installed by someone who\'s no longer around. Can you help?',
        answer: 'Yes. We see this regularly. We can assess the system, troubleshoot what\'s wrong, and either fix it or give you an honest recommendation on what\'s worth keeping.',
      },
    ],
  },
  {
    category: 'Whole House Audio & Outdoor AV',
    faqs: [
      {
        question: 'Can I add whole house audio to my existing home?',
        answer: 'Often yes. Sonos and similar wireless systems can be added to an existing home with minimal disruption. In-ceiling speakers in finished spaces sometimes require fishing wire — we minimize drywall impact and tell you upfront what\'s involved.',
      },
      {
        question: 'What outdoor speaker systems do you install?',
        answer: 'We install weatherproof in-ground, surface-mount, and rock-style speakers for patios, pool decks, and backyards. All outdoor equipment is rated for the Texas climate — heat, humidity, and UV exposure.',
      },
      {
        question: 'Can I get an outdoor projector for my covered patio?',
        answer: 'Yes. We ceiling-mount projectors under covered patios, run the wire clean through the structure, and pair it with a screen and outdoor speakers. A proper outdoor theater experience — not a portable setup.',
      },
    ],
  },
];

// Build FAQPage schema from all questions
const allFaqs = faqCategories.flatMap(c => c.faqs);
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": allFaqs.map(({ question, answer }) => ({
    "@type": "Question",
    "name": question,
    "acceptedAnswer": { "@type": "Answer", "text": answer }
  }))
};
---

<BaseLayout
  title="FAQ — Home Theater & AV Installation San Antonio TX | KZ Audio & Video"
  description="Answers to common questions about home theater installation, whole house audio, outdoor AV, and working with KZ Audio & Video in San Antonio TX."
  schema={[faqSchema, breadcrumb]}
>

  <!-- Hero -->
  <section class="section bg-charcoal pt-32">
    <div class="container-main">
      <p class="overline mb-3">Frequently Asked Questions</p>
      <h1 class="font-display text-h1 text-warm-white mb-6 max-w-3xl">
        Home Theater & AV Installation — Common Questions
      </h1>
      <p class="text-body-lg text-stone max-w-2xl">
        If you don't see what you're looking for here, call us at (210) 981-4098. We're happy to answer questions before any commitment.
      </p>
    </div>
  </section>

  <TrustBar />

  <!-- FAQ Sections -->
  {faqCategories.map(({ category, faqs }) => (
    <section class="section bg-slate-surface border-b border-smoke last:border-0">
      <div class="container-content">
        <h2 class="font-display text-h2 text-warm-white mb-10">{category}</h2>
        <div class="flex flex-col divide-y divide-smoke" id={`faq-${category.replace(/\s+/g, '-').toLowerCase()}`}>
          {faqs.map(({ question, answer }, i) => (
            <div class="py-5">
              <button
                type="button"
                class="w-full text-left flex justify-between items-start gap-4
                       font-sans font-semibold text-h4 text-warm-white
                       hover:text-gold transition-colors duration-fast"
                aria-expanded="false"
                aria-controls={`faq-answer-${category}-${i}`}
                data-faq-btn
              >
                <span>{question}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20" height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="flex-shrink-0 mt-0.5 transition-transform duration-fast"
                  aria-hidden="true"
                  data-faq-icon
                >
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </button>
              <div
                id={`faq-answer-${category}-${i}`}
                class="overflow-hidden max-h-0 transition-all duration-base"
                data-faq-panel
              >
                <p class="text-stone text-body leading-relaxed pt-4 pb-2">{answer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <CTASection
    heading="Still Have Questions?"
    body="Call us at (210) 981-4098 or book a free consultation. We'll come to your home and talk through what you're looking for — no pressure, no sales pitch."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>

<script>
  document.querySelectorAll('[data-faq-btn]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const panel = btn.nextElementSibling as HTMLElement;
      const icon  = btn.querySelector('[data-faq-icon]') as HTMLElement;
      btn.setAttribute('aria-expanded', String(!expanded));
      panel.style.maxHeight = expanded ? '0' : `${panel.scrollHeight}px`;
      icon.style.transform  = expanded ? '' : 'rotate(180deg)';
    });
  });
</script>
