---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CTASection from '../../../components/sections/CTASection.astro';

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": "Custom Star Wars Home Theater — San Antonio TX",
  "description": "Custom Star Wars themed dedicated home theater in San Antonio TX. JVC projector, built-in display wall, fixed-frame screen, Dolby Atmos surround. Designed around the client's collection.",
  "url": "https://kzaudioandvideo.com/projects/star-wars-home-theater-san-antonio/",
  "creator": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "telephone": "+12109814098",
    "url": "https://kzaudioandvideo.com"
  },
  "locationCreated": {
    "@type": "Place",
    "name": "San Antonio, TX"
  }
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": "https://kzaudioandvideo.com/home-theater-projects-san-antonio/" },
    { "@type": "ListItem", "position": 3, "name": "Star Wars Home Theater — San Antonio" }
  ]
};

const gallery = [
  { src: '/images/projects/davids-theater/david-theater-san-antonio-tx.jpg', alt: 'Star Wars home theater with custom built-in display wall in San Antonio Texas' },
  { src: '/images/projects/davids-theater/home-theater-from-rear.jpeg.jpg', alt: 'View from rear of Star Wars dedicated home theater' },
  { src: '/images/projects/davids-theater/home-theater-jvc.jpeg.jpg', alt: 'JVC projector installed in custom home theater' },
  { src: '/images/projects/davids-theater/home-theater-rear-side.jpeg.jpg', alt: 'Side view of dedicated theater room San Antonio' },
  { src: '/images/projects/davids-theater/home-theater-seating.jpeg.jpg', alt: 'Home theater seating in Star Wars themed room' },
  { src: '/images/projects/davids-theater/home-theater-seating-2.jpeg.jpg', alt: 'Theater seating arrangement with custom lighting' },
];
---

<BaseLayout
  title="Star Wars Home Theater San Antonio TX | KZ Audio & Video"
  description="Custom Star Wars themed dedicated home theater in San Antonio TX. JVC projector, built-in display wall, fixed-frame screen, Dolby Atmos surround. Designed around the client's collection. KZ Audio & Video (210) 981-4098."
  canonical="https://kzaudioandvideo.com/projects/star-wars-home-theater-san-antonio/"
  schema={[projectSchema, breadcrumb]}
>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="height:65vh;min-height:420px;">
    <img
      src="/images/projects/davids-theater/home-theater-front-view.jpeg.jpg"
      alt="Custom Star Wars themed home theater with projection screen and built-in display wall in San Antonio Texas"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0" style="background:linear-gradient(to top, rgba(14,16,18,0.92) 0%, rgba(14,16,18,0.55) 50%, rgba(14,16,18,0.3) 100%);" aria-hidden="true"></div>
    <div class="absolute inset-0 flex flex-col justify-end pb-14 px-6 sm:px-10 lg:px-16">
      <div class="container-main">
        <nav class="mb-4" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-[0.72rem] font-sans uppercase tracking-widest text-stone">
            <li><a href="/" class="hover:text-gold transition-colors">Home</a></li>
            <li aria-hidden="true" class="opacity-40">/</li>
            <li><a href="/home-theater-projects-san-antonio/" class="hover:text-gold transition-colors">Projects</a></li>
            <li aria-hidden="true" class="opacity-40">/</li>
            <li class="text-warm-white">Star Wars Theater</li>
          </ol>
        </nav>
        <p class="overline mb-3">Home Theater · San Antonio, TX</p>
        <h1 class="font-display text-warm-white mb-0" style="font-size:clamp(1.75rem,4vw,3rem);line-height:1.1;letter-spacing:-0.02em;">
          Custom Star Wars Home Theater — San Antonio, TX
        </h1>
      </div>
    </div>
  </section>

  <!-- Details bar -->
  <section class="bg-charcoal border-b border-smoke py-6">
    <div class="container-main">
      <dl class="flex flex-wrap gap-x-10 gap-y-3">
        <div class="flex flex-col gap-0.5">
          <dt class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">Location</dt>
          <dd class="text-warm-white text-sm font-sans font-semibold">San Antonio, TX</dd>
        </div>
        <div class="flex flex-col gap-0.5">
          <dt class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">Service</dt>
          <dd class="text-warm-white text-sm font-sans font-semibold">Dedicated Home Theater</dd>
        </div>
        <div class="flex flex-col gap-0.5">
          <dt class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">Projector</dt>
          <dd class="text-warm-white text-sm font-sans font-semibold">JVC</dd>
        </div>
        <div class="flex flex-col gap-0.5">
          <dt class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">Audio</dt>
          <dd class="text-warm-white text-sm font-sans font-semibold">Complete Dolby Atmos In-Wall & In-Ceiling</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Project details -->
  <section class="section bg-slate-surface">
    <div class="container-main">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2">
          <p class="overline mb-3">About This Project</p>
          <h2 class="font-display text-h2 text-warm-white mb-6">Not a Template Build</h2>
          <div class="flex flex-col gap-4 text-body text-stone leading-relaxed">
            <p>This San Antonio home theater is a fully custom build designed around the client's collection. Every element — from the built-in entertainment and display wall to the seating arrangement and lighting — was specified around the homeowner's vision, not a pre-packaged system.</p>
            <p>The JVC projector delivers reference-level image quality on a fixed-frame projection screen. In-wall and in-ceiling speakers handle a complete Dolby Atmos surround configuration — front stage, surrounds, and overhead channels — with no visible speaker boxes in the finished room.</p>
            <p>KZ Audio & Video handled full system design, custom built-in cabinetry coordination, installation, and calibration. This is what it looks like when a theater is built from a client's brief, not from a product catalog.</p>
          </div>
        </div>
        <div class="flex flex-col gap-4">
          <div class="card p-6">
            <h3 class="font-sans font-semibold text-warm-white mb-4 text-sm uppercase tracking-wider">Project Details</h3>
            <ul class="flex flex-col gap-3">
              {[
                { label: 'Equipment', value: 'JVC projector, fixed-frame projection screen, complete Dolby Atmos in-wall and in-ceiling surround system' },
                { label: 'Scope', value: 'Custom built-in entertainment and display wall, full system design and installation, calibration' },
                { label: 'Note', value: "Every design decision was built around the client's collection — this is not a template build" },
                { label: 'Location', value: 'San Antonio, TX' },
              ].map(({ label, value }) => (
                <li class="flex flex-col gap-0.5">
                  <span class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">{label}</span>
                  <span class="text-warm-white text-sm">{value}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <p class="overline mb-3">Project Gallery</p>
      <h2 class="font-display text-h2 text-warm-white mb-10">All Project Photos</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {gallery.map(({ src, alt }) => (
          <button
            class="proj-lb-trigger group overflow-hidden rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-gold"
            data-img={src}
            data-alt={alt}
            aria-label={`View full size: ${alt}`}
            type="button"
          >
            <div class="overflow-hidden aspect-video">
              <img
                src={src}
                alt={alt}
                class="w-full h-full object-cover transition-transform duration-slow group-hover:scale-[1.04]"
                loading="lazy"
                decoding="async"
              />
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Build Your Own Custom Theater?"
    body="Book a free in-home consultation. We come to you, assess the space, and design a system built around how you want to use it."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>

<!-- Lightbox -->
<div
  id="proj-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Project photo"
  style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(14,16,18,0.96); cursor:pointer; backdrop-filter:blur(8px);"
>
  <button
    id="proj-lb-close"
    aria-label="Close photo"
    style="position:absolute;top:1.25rem;right:1.5rem;background:none;border:none;color:#F2EDE6;font-size:1.75rem;cursor:pointer;line-height:1;opacity:0.7;transition:opacity 150ms;"
    onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'"
  >&#x2715;</button>
  <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:5rem 1.5rem 2rem;">
    <img
      id="proj-lb-img"
      src=""
      alt=""
      style="max-width:100%;max-height:78vh;object-fit:contain;border-radius:0.375rem;box-shadow:0 32px 80px rgba(0,0,0,0.8);"
    />
    <p id="proj-lb-caption" style="margin-top:1.25rem;font-family:'Jost',sans-serif;color:#A09080;font-size:0.8rem;text-align:center;max-width:56ch;line-height:1.6;"></p>
  </div>
</div>

<script>
  const lb      = document.getElementById('proj-lightbox') as HTMLElement;
  const lbImg   = document.getElementById('proj-lb-img') as HTMLImageElement;
  const lbCap   = document.getElementById('proj-lb-caption') as HTMLElement;
  const lbClose = document.getElementById('proj-lb-close') as HTMLElement;

  function openLb(img: string, alt: string) {
    lbImg.src = img;
    lbImg.alt = alt;
    lbCap.textContent = alt;
    lb.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeLb() {
    lb.style.display = 'none';
    document.body.style.overflow = '';
    lbImg.src = '';
  }

  document.querySelectorAll<HTMLElement>('.proj-lb-trigger').forEach(el => {
    const open = () => openLb(el.dataset.img ?? '', el.dataset.alt ?? '');
    el.addEventListener('click', open);
    el.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); } });
  });

  lb.addEventListener('click', (e) => { if (e.target !== lbImg) closeLb(); });
  lbClose.addEventListener('click', closeLb);
  document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Escape') closeLb(); });
</script>
