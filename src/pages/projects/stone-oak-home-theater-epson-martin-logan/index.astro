---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CTASection from '../../../components/sections/CTASection.astro';

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": "Stone Oak Home Theater — Epson Laser Projector & Martin Logan",
  "description": "Dedicated home theater in Stone Oak San Antonio — Epson laser projector, Screen Innovations screen, Martin Logan on-wall speakers, LED lighting. Installed by KZ Audio & Video.",
  "url": "https://kzaudioandvideo.com/projects/stone-oak-home-theater-epson-martin-logan/",
  "creator": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "telephone": "+12109814098",
    "url": "https://kzaudioandvideo.com"
  },
  "locationCreated": {
    "@type": "Place",
    "name": "Stone Oak, San Antonio, TX"
  }
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": "https://kzaudioandvideo.com/home-theater-projects-san-antonio/" },
    { "@type": "ListItem", "position": 3, "name": "Stone Oak Home Theater — Epson & Martin Logan" }
  ]
};

const gallery = [
  { src: '/images/projects/asanka-theater/projector-screen-martin-logan-san-antonio-home-theater.jpg', alt: 'Projection screen with Martin Logan speakers in Stone Oak San Antonio home theater' },
  { src: '/images/projects/asanka-theater/Epson-projector-san-antonio-theater.jpg', alt: 'Epson laser projector installation in San Antonio home theater' },
  { src: '/images/projects/asanka-theater/screen-innovations-projector-screen-san-antonio.jpg', alt: 'Screen Innovations fixed-frame projection screen in San Antonio' },
  { src: '/images/projects/asanka-theater/martin-logan-onwall-speaker-san-antonio.jpg', alt: 'Martin Logan on-wall speaker installed in San Antonio home theater' },
  { src: '/images/projects/asanka-theater/home-theater-led-lights-san-antonio.jpg', alt: 'LED accent lighting in San Antonio home theater' },
  { src: '/images/projects/asanka-theater/home-theater-projector-lights-on-better.jpeg.jpg', alt: 'Home theater with lights on showing full room' },
  { src: '/images/projects/asanka-theater/home-theater-projector-lights-out.jpeg.jpg', alt: 'Home theater in cinema mode lights out' },
  { src: '/images/projects/asanka-theater/home-theater-projector-glow.jpeg.jpg', alt: 'Projector glow in darkened home theater' },
  { src: '/images/projects/asanka-theater/home-theater-lights-off-black-room.jpeg.jpg', alt: 'Dedicated home theater with lights off' },
  { src: '/images/projects/asanka-theater/Front-Right-theater-Speaker-prewire-san-antonio.jpg', alt: 'Front right speaker pre-wire during construction' },
  { src: '/images/projects/asanka-theater/Front-left-theater-speaker-prewire-san-antonio.jpg', alt: 'Front left speaker pre-wire in San Antonio home theater' },
  { src: '/images/projects/asanka-theater/front-center-theater-speaker-san-antonio.jpg', alt: 'Center channel speaker installation San Antonio' },
  { src: '/images/projects/asanka-theater/left-rear-theater-speaker-prewire-san-antonio.jpg', alt: 'Left rear surround speaker pre-wire' },
  { src: '/images/projects/asanka-theater/right-rear-theater-speaker-san-antonio.jpg', alt: 'Right rear surround speaker installation' },
  { src: '/images/projects/asanka-theater/Home-theater-blue-screen-san-antonio.jpg', alt: 'Home theater test screen San Antonio' },
];
---

<BaseLayout
  title="Stone Oak Home Theater — Epson Laser Projector & Martin Logan | KZ Audio & Video"
  description="Dedicated home theater in Stone Oak San Antonio — Epson laser projector, Screen Innovations screen, Martin Logan on-wall speakers, LED lighting. Installed by KZ Audio & Video. (210) 981-4098."
  canonical="https://kzaudioandvideo.com/projects/stone-oak-home-theater-epson-martin-logan/"
  schema={[projectSchema, breadcrumb]}
>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="height:65vh;min-height:420px;">
    <img
      src="/images/projects/asanka-theater/san-antonio-home-theater-hero-projector.jpg"
      alt="Custom home theater installation in Stone Oak San Antonio TX with projection screen and surround sound"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0" style="background:linear-gradient(to top, rgba(14,16,18,0.92) 0%, rgba(14,16,18,0.55) 50%, rgba(14,16,18,0.3) 100%);" aria-hidden="true"></div>
    <div class="absolute inset-0 flex flex-col justify-end pb-14 px-6 sm:px-10 lg:px-16">
      <div class="container-main">
        <nav class="mb-4" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-[0.72rem] font-sans uppercase tracking-widest text-stone">
            <li><a href="/" class="hover:text-gold transition-colors">Home</a></li>
            <li aria-hidden="true" class="opacity-40">/</li>
            <li><a href="/home-theater-projects-san-antonio/" class="hover:text-gold transition-colors">Projects</a></li>
            <li aria-hidden="true" class="opacity-40">/</li>
            <li class="text-warm-white">Stone Oak Theater</li>
          </ol>
        </nav>
        <p class="overline mb-3">Home Theater · Stone Oak, San Antonio TX</p>
        <h1 class="font-display text-warm-white mb-0" style="font-size:clamp(1.75rem,4vw,3rem);line-height:1.1;letter-spacing:-0.02em;">
          Home Theater Installation — Stone Oak, San Antonio TX
        </h1>
      </div>
    </div>
  </section>

  <!-- Details bar -->
  <section class="bg-charcoal border-b border-smoke py-6">
    <div class="container-main">
      <dl class="flex flex-wrap gap-x-10 gap-y-3">
        <div class="flex flex-col gap-0.5">
          <dt class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">Location</dt>
          <dd class="text-warm-white text-sm font-sans font-semibold">Stone Oak, San Antonio TX (78258)</dd>
        </div>
        <div class="flex flex-col gap-0.5">
          <dt class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">Service</dt>
          <dd class="text-warm-white text-sm font-sans font-semibold">Dedicated Home Theater</dd>
        </div>
        <div class="flex flex-col gap-0.5">
          <dt class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">Projector</dt>
          <dd class="text-warm-white text-sm font-sans font-semibold">Epson Laser</dd>
        </div>
        <div class="flex flex-col gap-0.5">
          <dt class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">Speakers</dt>
          <dd class="text-warm-white text-sm font-sans font-semibold">Martin Logan On-Wall Front & Rear</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Project details -->
  <section class="section bg-slate-surface">
    <div class="container-main">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2">
          <p class="overline mb-3">About This Project</p>
          <h2 class="font-display text-h2 text-warm-white mb-6">Epson Laser + Screen Innovations + Martin Logan in Stone Oak</h2>
          <div class="flex flex-col gap-4 text-body text-stone leading-relaxed">
            <p>This Stone Oak dedicated theater pairs an Epson laser projector with a Screen Innovations fixed-frame screen — a combination that delivers exceptional image quality in a controlled-light environment. The laser source means no lamp to replace and consistent brightness over the life of the system.</p>
            <p>Martin Logan on-wall speakers handle the front stage and rear surrounds. Their low profile keeps the room clean while delivering the kind of clarity and imaging that traditional in-wall speakers can't match. Custom LED accent lighting ties the room together.</p>
            <p>KZ handled the complete build — pre-wire from rough-in through finished install, including the homeowner walkthrough and full system calibration. Photos document the project from speaker pre-wire through the finished theater.</p>
          </div>
        </div>
        <div class="flex flex-col gap-4">
          <div class="card p-6">
            <h3 class="font-sans font-semibold text-warm-white mb-4 text-sm uppercase tracking-wider">Project Details</h3>
            <ul class="flex flex-col gap-3">
              {[
                { label: 'Equipment', value: 'Epson laser projector, Screen Innovations fixed-frame screen, Martin Logan on-wall speakers front and rear, custom LED accent lighting' },
                { label: 'Scope', value: 'Full pre-wire through finished install including homeowner walkthrough and calibration' },
                { label: 'Location', value: 'Stone Oak, San Antonio TX (78258)' },
              ].map(({ label, value }) => (
                <li class="flex flex-col gap-0.5">
                  <span class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">{label}</span>
                  <span class="text-warm-white text-sm">{value}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <p class="overline mb-3">Project Gallery</p>
      <h2 class="font-display text-h2 text-warm-white mb-10">All Project Photos</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {gallery.map(({ src, alt }) => (
          <button
            class="proj-lb-trigger group overflow-hidden rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-gold"
            data-img={src}
            data-alt={alt}
            aria-label={`View full size: ${alt}`}
            type="button"
          >
            <div class="overflow-hidden aspect-video">
              <img
                src={src}
                alt={alt}
                class="w-full h-full object-cover transition-transform duration-slow group-hover:scale-[1.04]"
                loading="lazy"
                decoding="async"
              />
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Build Your Own Dedicated Theater?"
    body="Book a free in-home consultation. We come to you, assess the space, and design a system around how you actually live."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>

<!-- Lightbox -->
<div
  id="proj-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Project photo"
  style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(14,16,18,0.96); cursor:pointer; backdrop-filter:blur(8px);"
>
  <button
    id="proj-lb-close"
    aria-label="Close photo"
    style="position:absolute;top:1.25rem;right:1.5rem;background:none;border:none;color:#F2EDE6;font-size:1.75rem;cursor:pointer;line-height:1;opacity:0.7;transition:opacity 150ms;"
    onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'"
  >&#x2715;</button>
  <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:5rem 1.5rem 2rem;">
    <img
      id="proj-lb-img"
      src=""
      alt=""
      style="max-width:100%;max-height:78vh;object-fit:contain;border-radius:0.375rem;box-shadow:0 32px 80px rgba(0,0,0,0.8);"
    />
    <p id="proj-lb-caption" style="margin-top:1.25rem;font-family:'Jost',sans-serif;color:#A09080;font-size:0.8rem;text-align:center;max-width:56ch;line-height:1.6;"></p>
  </div>
</div>

<script>
  const lb      = document.getElementById('proj-lightbox') as HTMLElement;
  const lbImg   = document.getElementById('proj-lb-img') as HTMLImageElement;
  const lbCap   = document.getElementById('proj-lb-caption') as HTMLElement;
  const lbClose = document.getElementById('proj-lb-close') as HTMLElement;

  function openLb(img: string, alt: string) {
    lbImg.src = img;
    lbImg.alt = alt;
    lbCap.textContent = alt;
    lb.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeLb() {
    lb.style.display = 'none';
    document.body.style.overflow = '';
    lbImg.src = '';
  }

  document.querySelectorAll<HTMLElement>('.proj-lb-trigger').forEach(el => {
    const open = () => openLb(el.dataset.img ?? '', el.dataset.alt ?? '');
    el.addEventListener('click', open);
    el.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); } });
  });

  lb.addEventListener('click', (e) => { if (e.target !== lbImg) closeLb(); });
  lbClose.addEventListener('click', closeLb);
  document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Escape') closeLb(); });
</script>
