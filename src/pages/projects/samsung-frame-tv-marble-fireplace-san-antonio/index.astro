---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CTASection from '../../../components/sections/CTASection.astro';

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": "Samsung Frame TV on Marble Fireplace Wall — San Antonio TX",
  "description": "Samsung Frame TV flush-mounted on a marble fireplace wall with Sonos Arc soundbar. Zero visible wiring. Displays fine art when not in use. Installed by KZ Audio & Video in San Antonio TX.",
  "url": "https://kzaudioandvideo.com/projects/samsung-frame-tv-marble-fireplace-san-antonio/",
  "creator": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "telephone": "+12109814098",
    "url": "https://kzaudioandvideo.com"
  },
  "locationCreated": {
    "@type": "Place",
    "name": "San Antonio, TX"
  }
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": "https://kzaudioandvideo.com/home-theater-projects-san-antonio/" },
    { "@type": "ListItem", "position": 3, "name": "Samsung Frame TV on Marble Fireplace Wall" }
  ]
};

const gallery = [
  { src: '/images/projects/flat-tvs/frame-tv-on-marble-wall-san-antonio.jpg', alt: 'Samsung Frame TV installed on marble wall San Antonio' },
  { src: '/images/projects/flat-tvs/samsung-frame-tv-art-mode-san-antonio.jpg', alt: 'Samsung Frame TV in art mode displaying fine art' },
  { src: '/images/projects/flat-tvs/samsung-frame-tv-marble-install-san-antonio.jpg', alt: 'Frame TV installation process on marble fireplace wall' },
  { src: '/images/projects/flat-tvs/samsung-frame-tv-sonos-arc-gen4-san-antonio.jpg', alt: 'Samsung Frame TV with Sonos Arc Gen 4 soundbar' },
  { src: '/images/projects/flat-tvs/flat-tv-sonos-arc-install-san-antonio.jpg', alt: 'Sonos Arc soundbar installation below TV' },
  { src: '/images/projects/flat-tvs/flat-tv-surround-sound-san-antonio.jpg', alt: 'TV and surround sound installation San Antonio' },
  { src: '/images/projects/flat-tvs/fireplace-tv-mount-san-antonio.jpg', alt: 'TV mount on fireplace wall San Antonio' },
  { src: '/images/projects/flat-tvs/fireplace-tv-mount-flame-san-antonio.jpg', alt: 'TV mounted above fireplace with flames' },
  { src: '/images/projects/flat-tvs/samsung-tv-sonos-arc-san-antonio.jpg', alt: 'Samsung TV with Sonos Arc soundbar San Antonio' },
  { src: '/images/projects/flat-tvs/patio-outdoor-tv-install-san-antonio.jpg', alt: 'Outdoor patio TV installation San Antonio' },
];
---

<BaseLayout
  title="Samsung Frame TV on Marble Fireplace Wall San Antonio | KZ Audio & Video"
  description="Samsung Frame TV flush-mounted on a marble fireplace wall with Sonos Arc soundbar. Zero visible wiring. Displays fine art when not in use. Installed by KZ Audio & Video in San Antonio TX. (210) 981-4098."
  canonical="https://kzaudioandvideo.com/projects/samsung-frame-tv-marble-fireplace-san-antonio/"
  schema={[projectSchema, breadcrumb]}
>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="height:65vh;min-height:420px;">
    <img
      src="/images/projects/flat-tvs/samsung-frame-tv-marble-wall-san-antonio.jpg"
      alt="Samsung Frame TV installed on marble fireplace wall in San Antonio Texas custom home"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0" style="background:linear-gradient(to top, rgba(14,16,18,0.92) 0%, rgba(14,16,18,0.55) 50%, rgba(14,16,18,0.3) 100%);" aria-hidden="true"></div>
    <div class="absolute inset-0 flex flex-col justify-end pb-14 px-6 sm:px-10 lg:px-16">
      <div class="container-main">
        <nav class="mb-4" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-[0.72rem] font-sans uppercase tracking-widest text-stone">
            <li><a href="/" class="hover:text-gold transition-colors">Home</a></li>
            <li aria-hidden="true" class="opacity-40">/</li>
            <li><a href="/home-theater-projects-san-antonio/" class="hover:text-gold transition-colors">Projects</a></li>
            <li aria-hidden="true" class="opacity-40">/</li>
            <li class="text-warm-white">Samsung Frame TV</li>
          </ol>
        </nav>
        <p class="overline mb-3">TV Installation · San Antonio, TX</p>
        <h1 class="font-display text-warm-white mb-0" style="font-size:clamp(1.75rem,4vw,3rem);line-height:1.1;letter-spacing:-0.02em;">
          Samsung Frame TV — Marble Fireplace Wall Install, San Antonio TX
        </h1>
      </div>
    </div>
  </section>

  <!-- Details bar -->
  <section class="bg-charcoal border-b border-smoke py-6">
    <div class="container-main">
      <dl class="flex flex-wrap gap-x-10 gap-y-3">
        <div class="flex flex-col gap-0.5">
          <dt class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">Location</dt>
          <dd class="text-warm-white text-sm font-sans font-semibold">San Antonio, TX</dd>
        </div>
        <div class="flex flex-col gap-0.5">
          <dt class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">Service</dt>
          <dd class="text-warm-white text-sm font-sans font-semibold">TV Installation</dd>
        </div>
        <div class="flex flex-col gap-0.5">
          <dt class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">Equipment</dt>
          <dd class="text-warm-white text-sm font-sans font-semibold">Samsung Frame TV · Sonos Arc Soundbar</dd>
        </div>
        <div class="flex flex-col gap-0.5">
          <dt class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">Surface</dt>
          <dd class="text-warm-white text-sm font-sans font-semibold">Marble Fireplace Wall</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Project details -->
  <section class="section bg-slate-surface">
    <div class="container-main">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2">
          <p class="overline mb-3">About This Project</p>
          <h2 class="font-display text-h2 text-warm-white mb-6">Zero Visible Wiring on a Marble Wall</h2>
          <div class="flex flex-col gap-4 text-body text-stone leading-relaxed">
            <p>Marble doesn't drill like drywall. It requires diamond-tip bits, precise anchor placement, and no room for error. One bad cut and you've damaged a surface that can't be easily repaired. This install required careful planning before a single drill touched the wall.</p>
            <p>The Samsung Frame TV is flush-mounted on a custom low-profile bracket. The Sonos Arc soundbar sits below. Zero visible wiring — all cable management was handled in the wall and hidden behind the TV's mounting system. When the TV is on, it disappears into the wall. When it's off, Art Mode kicks in and it displays fine art from a curated library.</p>
            <p>This is what TV installation looks like when it's done properly — not a TV hung with two bolts and cables taped to the back of the wall.</p>
          </div>
        </div>
        <div class="flex flex-col gap-4">
          <div class="card p-6">
            <h3 class="font-sans font-semibold text-warm-white mb-4 text-sm uppercase tracking-wider">Project Details</h3>
            <ul class="flex flex-col gap-3">
              {[
                { label: 'Equipment', value: 'Samsung Frame TV, Sonos Arc soundbar, custom low-profile wall mount' },
                { label: 'The challenge', value: "Marble doesn't drill like drywall — requires diamond-tip bits, precise anchor placement, and no room for error" },
                { label: 'Result', value: 'Zero visible wiring. Displays fine art in Art Mode when not in use' },
                { label: 'Location', value: 'San Antonio, TX' },
              ].map(({ label, value }) => (
                <li class="flex flex-col gap-0.5">
                  <span class="text-[0.65rem] font-sans uppercase tracking-widest text-stone">{label}</span>
                  <span class="text-warm-white text-sm">{value}</span>
                </li>
              ))}
            </ul>
          </div>
          <a href="/contact-kz-audio-video-san-antonio-tx/" class="btn-primary gold-shimmer text-center">
            Book a Free Consultation
          </a>
          <a href="tel:2109814098" class="btn-ghost text-center">
            Call (210) 981-4098
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <p class="overline mb-3">Project Gallery</p>
      <h2 class="font-display text-h2 text-warm-white mb-10">All Project Photos</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {gallery.map(({ src, alt }) => (
          <button
            class="proj-lb-trigger group overflow-hidden rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-gold"
            data-img={src}
            data-alt={alt}
            aria-label={`View full size: ${alt}`}
            type="button"
          >
            <div class="overflow-hidden aspect-video">
              <img
                src={src}
                alt={alt}
                class="w-full h-full object-cover transition-transform duration-slow group-hover:scale-[1.04]"
                loading="lazy"
                decoding="async"
              />
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Want a Clean TV Install in Your Home?"
    body="Book a free consultation. We'll assess the wall, specify the right mount, and install it with zero visible wiring."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>

<!-- Lightbox -->
<div
  id="proj-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Project photo"
  style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(14,16,18,0.96); cursor:pointer; backdrop-filter:blur(8px);"
>
  <button
    id="proj-lb-close"
    aria-label="Close photo"
    style="position:absolute;top:1.25rem;right:1.5rem;background:none;border:none;color:#F2EDE6;font-size:1.75rem;cursor:pointer;line-height:1;opacity:0.7;transition:opacity 150ms;"
    onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'"
  >&#x2715;</button>
  <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:5rem 1.5rem 2rem;">
    <img
      id="proj-lb-img"
      src=""
      alt=""
      style="max-width:100%;max-height:78vh;object-fit:contain;border-radius:0.375rem;box-shadow:0 32px 80px rgba(0,0,0,0.8);"
    />
    <p id="proj-lb-caption" style="margin-top:1.25rem;font-family:'Jost',sans-serif;color:#A09080;font-size:0.8rem;text-align:center;max-width:56ch;line-height:1.6;"></p>
  </div>
</div>

<script>
  const lb      = document.getElementById('proj-lightbox') as HTMLElement;
  const lbImg   = document.getElementById('proj-lb-img') as HTMLImageElement;
  const lbCap   = document.getElementById('proj-lb-caption') as HTMLElement;
  const lbClose = document.getElementById('proj-lb-close') as HTMLElement;

  function openLb(img: string, alt: string) {
    lbImg.src = img;
    lbImg.alt = alt;
    lbCap.textContent = alt;
    lb.style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeLb() {
    lb.style.display = 'none';
    document.body.style.overflow = '';
    lbImg.src = '';
  }

  document.querySelectorAll<HTMLElement>('.proj-lb-trigger').forEach(el => {
    const open = () => openLb(el.dataset.img ?? '', el.dataset.alt ?? '');
    el.addEventListener('click', open);
    el.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); } });
  });

  lb.addEventListener('click', (e) => { if (e.target !== lbImg) closeLb(); });
  lbClose.addEventListener('click', closeLb);
  document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Escape') closeLb(); });
</script>
