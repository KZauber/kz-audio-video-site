---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HeroSection from '../../../components/sections/HeroSection.astro';
import TrustBar from '../../../components/sections/TrustBar.astro';
import CTASection from '../../../components/sections/CTASection.astro';
import FAQAccordion from '../../../components/sections/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "KZ Audio & Video",
  "url": "https://kzaudioandvideo.com",
  "telephone": "+12109814098",
  "description": "Home theater, whole house audio, outdoor AV, and security camera installation in San Antonio TX. In business since 1997.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "San Antonio",
    "addressRegion": "TX",
    "addressCountry": "US"
  },
  "areaServed": {
    "@type": "City",
    "name": "San Antonio",
    "containedInPlace": {
      "@type": "State",
      "name": "Texas"
    }
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "AV Installation Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Home Theater Installation" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Whole House Audio" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Outdoor AV Installation" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Security Camera Installation" } }
    ]
  }
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Service Areas", "item": "https://kzaudioandvideo.com/service-areas/" },
    { "@type": "ListItem", "position": 3, "name": "San Antonio" }
  ]
};

const faqs = [
  {
    question: 'Do you serve all San Antonio neighborhoods?',
    answer: 'Yes. We install throughout Greater San Antonio — from the North Side and Stone Oak to the Medical Center area, Alamo Heights, Olmos Park, and everything in between. If you\'re in Bexar County, we\'re there.',
  },
  {
    question: 'How long has KZ Audio & Video been in San Antonio?',
    answer: 'Since 1997. We\'ve been installing home AV systems in San Antonio homes for over 25 years. Kelly, Billy, and Julian have collectively seen just about every home layout, wiring situation, and custom build scenario the city has to offer.',
  },
  {
    question: 'Can you pre-wire a new construction home in San Antonio?',
    answer: 'Absolutely — and it\'s the best time to do it. We work with builders and homeowners during the framing and rough-in stages to run all the conduit, speaker wire, HDMI, and low-voltage cabling before drywall goes up. That eliminates wall fishing later and gives you a cleaner result.',
  },
  {
    question: 'What does a home theater installation cost in San Antonio?',
    answer: 'It depends on the scope — room size, projector vs. flat panel, number of speakers, seating, and acoustic treatment. We don\'t publish package prices because every room is different. Book a free consultation and we\'ll walk through the space and give you an honest number.',
  },
];
---

<BaseLayout
  title="Home Theater Installation San Antonio TX | KZ Audio & Video"
  description="Home theater, whole house audio, outdoor AV, and security camera installation throughout San Antonio TX. In business since 1997. Call (210) 981-4098."
  schema={[schema, breadcrumb]}
>

  <HeroSection
    heading="Home Theater & AV Installation in San Antonio TX"
    subhead="San Antonio's most experienced AV installer — home theaters, whole house audio, outdoor AV, and security cameras since 1997."
    imageSrc="/images/projects/monty-theater/home-theater-near-san-antonio-hero.jpg"
    imageAlt="Custom home theater installation in San Antonio Texas"
    compact={true}
  />

  <TrustBar />

  <!-- Services -->
  <section class="section bg-slate-surface">
    <div class="container-main">
      <p class="overline mb-3">San Antonio AV Services</p>
      <h2 class="font-display text-h2 text-warm-white mb-4">
        Everything Your San Antonio Home Needs
      </h2>
      <p class="text-body-lg text-stone mb-10 max-w-2xl">
        Four core services. One installer. We've handled every combination of these in San Antonio homes — from a simple patio speaker setup to a fully dedicated home theater with acoustic treatment and 4K projection.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-10">
        {[
          {
            title: 'Home Theater',
            desc: 'Dedicated theater rooms and media rooms with 4K projection or large-format displays, Dolby Atmos surround sound, and acoustic treatment designed for your space.',
            href: '/home-theater-installation-san-antonio-tx/',
          },
          {
            title: 'Whole House Audio',
            desc: 'Sonos and multi-zone audio systems that put music in every room — kitchen, patio, master bedroom, pool — all controlled from your phone.',
            href: '/whole-house-audio-san-antonio/',
          },
          {
            title: 'Outdoor AV',
            desc: 'Weatherproof displays, outdoor speakers, and covered-patio entertainment systems built for San Antonio\'s climate and outdoor lifestyle.',
            href: '/outdoor-audio-video-san-antonio/',
          },
          {
            title: 'Security Cameras',
            desc: 'Professional camera systems with remote viewing, local storage, and installations that don\'t compromise your home\'s curb appeal.',
            href: '/security-camera-installation-san-antonio/',
          },
        ].map(({ title, desc, href }) => (
          <a href={href} class="card card-hover flex flex-col gap-3 p-6 reveal">
            <h3 class="font-sans font-semibold text-h4 text-warm-white">{title}</h3>
            <p class="text-body text-stone leading-relaxed">{desc}</p>
            <span class="text-gold text-body-sm font-sans font-medium mt-auto flex items-center gap-1">
              Learn more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why KZ in San Antonio -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="overline mb-3 reveal">25+ Years in San Antonio</p>
          <h2 class="font-display text-h2 text-warm-white mb-6 reveal reveal-delay-1">
            This Is Our City. We Know These Homes.
          </h2>
          <div class="flex flex-col gap-4 reveal reveal-delay-2">
            <p class="text-body-lg text-stone" style="font-weight:300;">
              KZ Audio & Video has been part of the San Antonio community since 1997. We've installed in Alamo Heights ranch houses, Stone Oak custom builds, Medical Center townhomes, and new construction subdivisions on the far North Side. We know how these homes are wired, how the acoustics behave, and what works.
            </p>
            <p class="text-body text-stone">
              Kelly, Billy, and Julian aren't a franchise or a big-box contractor crew. When you call us, the same people who answer the phone show up at your house. Every install is treated like it's our own home.
            </p>
            <p class="text-body text-stone">
              Every project starts with a free in-home consultation — no showroom visit, no sales pitch, no obligation. We come to you, see the space, and tell you exactly what's possible.
            </p>
          </div>
        </div>
        <div class="flex flex-col gap-4 reveal reveal-delay-3">
          {[
            { label: 'In business since', value: '1997' },
            { label: 'Google Reviews', value: '5.0 Stars' },
            { label: 'Consultation fee', value: 'Free' },
            { label: 'Service area', value: 'All of Bexar County' },
          ].map(({ label, value }) => (
            <div class="flex items-center justify-between py-4 border-b border-smoke/60">
              <span class="text-body text-stone font-sans">{label}</span>
              <span class="font-display font-bold text-gold" style="font-size:1.2rem;">{value}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <FAQAccordion
    heading="Home Theater & AV Installation San Antonio — FAQs"
    faqs={faqs}
  />

  <CTASection
    heading="Book a Free Consultation in San Antonio"
    body="We come to your home, look at the space, and tell you exactly what's possible — equipment, layout, cost. No pressure, no obligation."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>
