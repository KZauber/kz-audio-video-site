---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServicesGrid from '../../components/sections/ServicesGrid.astro';
import ProjectsGrid from '../../components/sections/ProjectsGrid.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import CTASection from '../../components/sections/CTASection.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Home Theater Installation New Braunfels",
  "provider": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "url": "https://kzaudioandvideo.com",
    "telephone": "+12109814098"
  },
  "areaServed": "New Braunfels, TX",
  "description": "Custom home theater and AV installation in New Braunfels TX.",
  "url": "https://kzaudioandvideo.com/home-theater-installation-new-braunfels-tx/"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Home Theater Installation New Braunfels TX" }
  ]
};

const projects = [
  {
    title: 'Dedicated Home Theater — Canyon Lake TX',
    location: 'Canyon Lake, TX',
    service: 'Home Theater',
    description: 'Full theater room with custom leather power recliner seating, blue LED accent lighting, projection system, and in-wall surround sound.',
    imageSrc: '/images/projects/monty-theater/Canyon-Lake-Tesac-Home-Theater-Custom-Seating.jpeg.jpg',
    imageAlt: 'Custom home theater with leather recliners and blue LED lighting in Canyon Lake Texas',
  },
  {
    title: 'Dedicated Home Theater — San Antonio TX',
    location: 'San Antonio, TX',
    service: 'Home Theater',
    description: 'Epson projector, Screen Innovations fixed-frame screen, Martin Logan on-wall speakers, LED accent lighting.',
    imageSrc: '/images/projects/asanka-theater/theater-room-san-antonio-tx.jpg',
    imageAlt: 'Home theater installation in San Antonio Texas with projection screen and surround sound',
  },
];

const featured = {
  name: 'San Antonio Homeowner',
  location: 'San Antonio, TX',
  service: 'Home Theater Client — Nearly 10 Years',
  quote: "I've been a customer of KZ Audio for going on a decade. Kelly and crew have always been great to work with. They're honest and will recommend what actually works for your situation rather than upselling you on equipment you don't need.",
};
---

<BaseLayout
  title="Home Theater Installation New Braunfels TX | KZ Audio & Video"
  description="Custom home theater and AV installation in New Braunfels TX. In the audio business since 1997. Call (210) 981-4098."
  schema={[schema, breadcrumb]}
>

  <HeroSection
    overline="Home Theater Installation · New Braunfels · Hill Country / Comal County · Since 2001"
    heading="Home Theater Installation in New Braunfels, TX"
    subhead="KZ Audio & Video designs and installs custom home theaters, whole-house audio, and outdoor AV systems in New Braunfels and across the Hill Country / Comal County. New Braunfels, TX — a fast-growing Hill Country community between San Antonio and Austin. In the audio business since 1997."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryCta="Or call: (210) 981-4098"
    secondaryHref="tel:2109814098"
    imageSrc="/images/projects/asanka-theater/theater-room-san-antonio-tx.jpg"
    imageAlt="Custom home theater installation in New Braunfels Texas Hill Country"
  />

  <TrustBar />

  <ServicesGrid
    intro="KZ Audio & Video serves New Braunfels and the surrounding Hill Country / Comal County. We design, install, and service custom home AV systems."
  />

  <ProjectsGrid
    projects={projects}
    overline="Recent Projects"
    heading="Home Theater Installs Near New Braunfels"
  />

  <TestimonialsSection featured={featured} />

  <!-- New Braunfels Local Context -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <p class="overline mb-3 reveal">About New Braunfels</p>
      <h2 class="font-display text-h2 text-warm-white mb-8 reveal reveal-delay-1">
        One of Texas's Fastest-Growing Custom Home Markets
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-12">
        <div>
          <p class="text-body-lg text-stone mb-6 reveal reveal-delay-2">
            New Braunfels has been one of the fastest-growing cities in the entire United States for several consecutive years. That growth has brought serious custom home construction to Comal County — from master-planned communities off IH-35 to larger rural custom lots in the surrounding Hill Country. We serve homeowners throughout New Braunfels and regularly work with builders active in the area.
          </p>
          <p class="text-body text-stone reveal reveal-delay-3">
            New Braunfels sits about halfway between San Antonio and Austin — a location that draws buyers from both metros who want Hill Country space without sacrificing access to the city. Many of these buyers are building or purchasing their first true custom home and want AV done right from the ground up. Pre-wire through final programming — that's where we come in.
          </p>
        </div>
        <div class="flex flex-col gap-6">
          <div class="reveal reveal-delay-2">
            <h3 class="font-sans font-semibold text-warm-white mb-2">New Construction & Existing Homes</h3>
            <p class="text-body-sm text-stone">Whether you're pre-wiring a new build or upgrading an existing home in New Braunfels, the process is the same: we design around your specific space and install it ourselves.</p>
          </div>
          <div class="reveal reveal-delay-3">
            <h3 class="font-sans font-semibold text-warm-white mb-2">One Team, Every Install</h3>
            <p class="text-body-sm text-stone">Kelly, Billy, and Julian do every install. The same people who spec your system are the ones who show up to build it.</p>
          </div>
          <div class="reveal reveal-delay-4">
            <h3 class="font-sans font-semibold text-warm-white mb-2">Free Consultation in New Braunfels</h3>
            <p class="text-body-sm text-stone">We make the drive to New Braunfels for every consultation. Look at the space, discuss your goals, give you a real number. No charge, no obligation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Get Started in New Braunfels?"
    body="Book a free, no-pressure consultation. We'll come to your home in New Braunfels and talk through what's possible."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>
