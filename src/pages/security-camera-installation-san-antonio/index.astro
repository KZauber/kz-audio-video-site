---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import FAQAccordion from '../../components/sections/FAQAccordion.astro';
import CTASection from '../../components/sections/CTASection.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Security Camera Installation",
  "provider": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "url": "https://kzaudioandvideo.com",
    "telephone": "+12109814098"
  },
  "areaServed": "San Antonio, TX",
  "description": "Security camera installation in San Antonio TX. Indoor and outdoor cameras integrated into your home technology setup. Professional installation, remote access via phone.",
  "url": "https://kzaudioandvideo.com/security-camera-installation-san-antonio/"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Security Camera Installation San Antonio" }
  ]
};

const faqs = [
  {
    question: 'What types of security cameras do you install?',
    answer: 'We install wired and wireless indoor and outdoor security cameras — Hikvision, Axis, and similar professional-grade systems. We also install doorbell cameras and integrate camera systems with existing home technology setups. We recommend wired systems for permanent installations — they\'re more reliable, less susceptible to interference, and don\'t rely on Wi-Fi coverage.',
  },
  {
    question: 'Can I monitor my cameras remotely from my phone?',
    answer: 'Yes. Every system we install includes remote access — you can view live feeds, review recorded footage, and receive motion notifications from your iOS or Android device. We configure the app, walk you through it, and make sure you know how to use it before we leave.',
  },
  {
    question: 'How many cameras do I need for my home?',
    answer: 'Most residential installs run four to twelve cameras covering main entry points, driveways, garages, backyards, and side yards. We assess your property and coverage goals and recommend the minimum number that gives you real coverage — not an upsell to cameras you don\'t need.',
  },
  {
    question: 'Do you integrate cameras with home automation systems?',
    answer: 'Yes. We can integrate camera feeds with existing home automation platforms and tie into your existing network infrastructure. If you have a smart home system already, we work with it. If you\'re building new, we design the camera system alongside your AV and low voltage installation.',
  },
  {
    question: 'Do you install cameras in new construction?',
    answer: 'Yes — new construction is ideal for camera installation because we can run wiring before the walls are closed. We work with custom home builders across San Antonio and the Hill Country and coordinate camera pre-wire alongside all other low voltage work.',
  },
];

const featured = {
  name: 'San Antonio Homeowner',
  location: 'San Antonio, TX',
  service: 'Home AV Client — Nearly 10 Years',
  quote: "They're honest and will recommend what actually works for your situation rather than upselling you on equipment you don't need. I've never had a bad experience with them and would absolutely recommend them.",
};
---

<BaseLayout
  title="Security Camera Installation San Antonio TX | KZ Audio & Video"
  description="Security camera installation in San Antonio TX. Indoor and outdoor cameras, remote access, professional installation. Integrated with your home technology setup. Call (210) 981-4098."
  schema={[schema, breadcrumb]}
>

  <HeroSection
    overline="Security Cameras · San Antonio · Hill Country · Since 2001"
    heading="Security Camera Installation in San Antonio TX"
    subhead="Indoor and outdoor camera systems professionally installed and integrated into your home technology setup. Remote access from your phone. KZ Audio & Video has been handling low voltage installation in San Antonio since 2001."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryCta="Or call: (210) 981-4098"
    secondaryHref="tel:2109814098"
    imageSrc="/images/projects/monty-theater/Home-Theater-Design-Build-Near-San-Antonio-Texas.jpeg.jpg"
    imageAlt="Professional security camera installation in San Antonio Texas custom home"
  />

  <TrustBar />

  <!-- Services -->
  <section class="section bg-slate-surface">
    <div class="container-main">
      <p class="overline mb-3">Camera Systems</p>
      <h2 class="font-display text-h2 text-warm-white mb-6">
        Professional Installation. Remote Access. No Guesswork.
      </h2>
      <p class="text-body-lg text-stone mb-12 max-w-2xl">
        Consumer camera systems are easy to install yourself. Professional camera systems — properly positioned, wired, and configured — are a different category. We install systems that give you real coverage and remote access that actually works.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Outdoor Cameras', desc: 'Weather-resistant cameras covering driveways, entries, garages, side yards, and backyards. Properly aimed, properly lit, properly wired.' },
          { title: 'Indoor Cameras', desc: 'Interior cameras for entry points, common areas, and any space you want visibility into. Discreet mounting, clean installation.' },
          { title: 'Wired NVR Systems', desc: 'Network video recorder systems with local storage and remote access. More reliable than cloud-only systems. Footage stored on-site.' },
          { title: 'Doorbell Cameras', desc: 'Video doorbell installation — wired for reliability, with remote access and motion notifications to your phone.' },
          { title: 'New Construction Pre-Wire', desc: 'Camera wire runs at rough-in stage in new construction. Coordinate alongside AV and low voltage for a complete installation.' },
          { title: 'Home Automation Integration', desc: 'Camera systems integrated with existing home automation and smart home platforms. One app, full visibility.' },
        ].map(({ title, desc }) => (
          <div class="card p-7 flex flex-col gap-3">
            <h3 class="font-sans font-semibold text-h4 text-warm-white">{title}</h3>
            <p class="text-body-sm text-stone leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <TestimonialsSection featured={featured} />

  <FAQAccordion
    heading="Security Camera Installation — Frequently Asked Questions"
    faqs={faqs}
  />

  <CTASection
    heading="Get Real Camera Coverage for Your Home"
    body="Book a free consultation. We'll assess your property, talk through coverage goals, and give you a quote — no pressure."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>
