---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServicesGrid from '../../components/sections/ServicesGrid.astro';
import ProjectsGrid from '../../components/sections/ProjectsGrid.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import CTASection from '../../components/sections/CTASection.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Home Theater Installation Boerne",
  "provider": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "url": "https://kzaudioandvideo.com",
    "telephone": "+12109814098"
  },
  "areaServed": "Boerne, TX",
  "description": "Custom home theater and AV installation in Boerne TX and the surrounding Hill Country.",
  "url": "https://kzaudioandvideo.com/home-theater-installation-boerne-tx/"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Home Theater Installation Boerne TX" }
  ]
};

const projects = [
  {
    title: 'Dedicated Home Theater — Canyon Lake TX',
    location: 'Canyon Lake, TX',
    service: 'Home Theater',
    description: 'Full theater room with custom leather power recliner seating, blue LED accent lighting, projection system, and in-wall surround sound.',
    imageSrc: '/images/projects/monty-theater/Canyon-Lake-Tesac-Home-Theater-Custom-Seating.jpeg.jpg',
    imageAlt: 'Custom home theater with leather recliners and blue LED lighting in Canyon Lake Texas',
  },
  {
    title: 'Dedicated Home Theater — San Antonio TX',
    location: 'San Antonio, TX',
    service: 'Home Theater',
    description: 'Epson projector, Screen Innovations fixed-frame screen, Martin Logan on-wall speakers, LED accent lighting.',
    imageSrc: '/images/projects/asanka-theater/theater-room-san-antonio-tx.jpg',
    imageAlt: 'Home theater installation in San Antonio Texas with projection screen and surround sound',
  },
];

const featured = {
  name: 'San Antonio Homeowner',
  location: 'San Antonio, TX',
  service: 'Home Theater Client — Nearly 10 Years',
  quote: "I've been a customer of KZ Audio for going on a decade. Kelly and crew have always been great to work with. They're honest and will recommend what actually works for your situation rather than upselling you on equipment you don't need.",
};
---

<BaseLayout
  title="Home Theater Installation Boerne TX | KZ Audio & Video"
  description="Custom home theater and AV installation in Boerne TX and the surrounding Hill Country. No subcontractors. In the audio business since 1997. Call (210) 981-4098."
  schema={[schema, breadcrumb]}
>

  <HeroSection
    overline="Home Theater Installation · Boerne · Hill Country · Since 2001"
    heading="Home Theater Installation in Boerne, TX"
    subhead="KZ Audio & Video designs and installs custom home theaters, whole-house audio, and outdoor AV systems in Boerne and across the Hill Country. Boerne, TX — in the heart of the Texas Hill Country, about 30 miles northwest of San Antonio. In the audio business since 1997. No subcontractors — ever."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryCta="Or call: (210) 981-4098"
    secondaryHref="tel:2109814098"
    imageSrc="/images/projects/monty-theater/Home-Theater-Design-Build-Near-San-Antonio-Texas.jpeg.jpg"
    imageAlt="Custom home theater installation in Boerne Texas Hill Country"
  />

  <TrustBar />

  <ServicesGrid
    intro="KZ Audio & Video serves Boerne and the surrounding Hill Country. We design, install, and service custom home AV systems — no subcontractors, no third-party labor."
  />

  <ProjectsGrid
    projects={projects}
    overline="Recent Projects"
    heading="Home Theater Installs Near Boerne"
  />

  <TestimonialsSection featured={featured} />

  <!-- Boerne Local Context -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <p class="overline mb-3 reveal">About Boerne</p>
      <h2 class="font-display text-h2 text-warm-white mb-8 reveal reveal-delay-1">
        Why Boerne Homeowners Call KZ
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-12">
        <div>
          <p class="text-body-lg text-stone mb-6 reveal reveal-delay-2">
            Boerne sits about 30 miles northwest of San Antonio on IH-10, right at the start of the Texas Hill Country. It's one of the fastest-growing communities in Kendall County — and the custom home construction happening along Highway 46 and Cibolo Creek Ranch Road is some of the most active we see anywhere in our service area.
          </p>
          <p class="text-body text-stone reveal reveal-delay-3">
            We've worked with custom builders and homeowners in Boerne's established neighborhoods and its newer communities alike. Theater rooms, whole-house audio, outdoor speaker systems on limestone terraces — Boerne properties tend to have the space and the layout to do it right. That's the kind of project we're built for.
          </p>
        </div>
        <div class="flex flex-col gap-6">
          <div class="reveal reveal-delay-2">
            <h3 class="font-sans font-semibold text-warm-white mb-2">No Subcontractors — Ever</h3>
            <p class="text-body-sm text-stone">Every install in Boerne is done by Kelly, Billy, or Julian. Not a subcontractor handed a work order. The same people who designed your system show up to install it.</p>
          </div>
          <div class="reveal reveal-delay-3">
            <h3 class="font-sans font-semibold text-warm-white mb-2">In the Audio Business Since 1997</h3>
            <p class="text-body-sm text-stone">Kelly started Audio Outlet in 1997 and has been doing home AV since 2001. That's over two decades of Hill Country installs — enough experience to know what works in these rooms and what doesn't.</p>
          </div>
          <div class="reveal reveal-delay-4">
            <h3 class="font-sans font-semibold text-warm-white mb-2">We Drive to Boerne — No Charge</h3>
            <p class="text-body-sm text-stone">Your consultation is free. We come to Boerne, walk your space, and tell you exactly what's possible. No charge, no obligation, no pressure.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Get Started in Boerne?"
    body="Book a free, no-pressure consultation. We'll come to your home in Boerne and talk through what's possible."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>
