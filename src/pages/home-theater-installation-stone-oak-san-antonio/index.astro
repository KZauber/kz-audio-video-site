---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ProjectsGrid from '../../components/sections/ProjectsGrid.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import FAQAccordion from '../../components/sections/FAQAccordion.astro';
import CTASection from '../../components/sections/CTASection.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Home Theater Installation Stone Oak TX",
  "provider": {
    "@type": "LocalBusiness",
    "@id": "https://kzaudioandvideo.com/#business",
    "name": "KZ Audio & Video",
    "url": "https://kzaudioandvideo.com",
    "telephone": "+12109814098"
  },
  "areaServed": "Stone Oak, San Antonio, TX",
  "serviceType": "Home Theater Installation",
  "description": "Custom home theater and AV installation in Stone Oak and north San Antonio. Dedicated theater rooms, whole-house audio, outdoor AV, and Samsung Frame TV installations. KZ Audio & Video — in the audio business since 1997.",
  "url": "https://kzaudioandvideo.com/home-theater-installation-stone-oak-san-antonio/"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Home Theater Installation Stone Oak TX" }
  ]
};

const projects = [
  {
    title: 'Dedicated Home Theater — Stone Oak, San Antonio TX',
    location: 'Stone Oak, San Antonio, TX',
    service: 'Home Theater',
    description: 'Epson projector, Screen Innovations fixed-frame screen, Martin Logan on-wall speakers front and rear, LED accent lighting. Pre-wire through finished install with homeowner walkthrough.',
    imageSrc: '/images/projects/asanka-theater/san-antonio-home-theater-project-cover.jpg',
    imageAlt: 'Custom home theater installation Stone Oak San Antonio TX with projection screen and surround sound',
    href: '/projects/stone-oak-home-theater-epson-martin-logan/',
  },
  {
    title: 'New Construction Home Theater — Stone Oak TX',
    location: 'Stone Oak, San Antonio, TX',
    service: 'Home Theater',
    description: 'New construction dedicated theater room. Full pre-wire, Epson projector, Martin Logan speakers, custom leather seating platform. Built from rough-in to final calibration.',
    imageSrc: '/images/projects/young-theater/stone-oak-home-theater-hero.jpg',
    imageAlt: 'New construction home theater Stone Oak San Antonio TX with leather seating and projection screen',
    href: '/projects/stone-oak-new-construction-home-theater/',
  },
];

const featured = {
  name: 'San Antonio Homeowner',
  location: 'Stone Oak, San Antonio, TX',
  service: 'Home Theater Client — Nearly 10 Years',
  quote: "They're honest and will recommend what actually works for your situation rather than upselling you on equipment you don't need. I've never had a bad experience with them and would absolutely recommend them to anyone looking for AV services.",
};

const faqs = [
  {
    question: 'How often do you work in Stone Oak?',
    answer: 'Stone Oak and the surrounding north San Antonio area — Rogers Ranch, Sonterra, The Vineyard, Shavano Park, and the newer communities along US-281 — is one of our highest-volume service areas. We are in this part of the city regularly. There is no travel fee and the consultation is always free.',
  },
  {
    question: 'Do you have completed projects in Stone Oak we can reference?',
    answer: 'Yes. We have two completed Stone Oak theater projects documented on our site — one in an existing home with an Epson projector and Martin Logan speakers, and one in a new construction build documented from rough-in through finished install. Both were built in the 78258 area. We can walk you through either one during your consultation.',
  },
  {
    question: 'What does a home theater installation cost in the Stone Oak area?',
    answer: 'A media room conversion — large 4K display, 5.1 surround or soundbar, clean wiring — typically runs $5,000–$12,000. A mid-tier dedicated theater room with 4K projection, Dolby Atmos, and tiered seating runs $15,000–$40,000. A premium theater with laser projection, motorized seating, and full automation runs $40,000–$80,000+. We give you a detailed written quote after seeing the space.',
  },
  {
    question: 'Can you pre-wire a new build in Stone Oak or north San Antonio?',
    answer: 'Yes — and this is exactly what we do. We have active builder relationships throughout north San Antonio and handle pre-wire, rough-in, trim-out, system programming, and the homeowner walkthrough on new construction projects. If your home is still framing or in rough-in, contact us now — pre-wire has to happen before the walls close.',
  },
  {
    question: 'Can you mount a Samsung Frame TV on a fireplace or stone wall?',
    answer: 'Yes. We have done several of these in Stone Oak — including a Samsung Frame TV flush-mounted on a custom marble fireplace wall with zero visible wiring. Stone and tile mounting requires different anchoring than drywall, and in-wall power solutions keep everything clean. We handle the full install.',
  },
];
---

<BaseLayout
  title="Home Theater Installation Stone Oak TX | KZ Audio & Video"
  description="Custom home theater installation in Stone Oak and north San Antonio. Two completed Stone Oak theater projects on record. Whole-house audio, outdoor AV, TV mounting. Call (210) 981-4098."
  schema={[schema, breadcrumb]}
>

  <HeroSection
    overline="Stone Oak · North San Antonio · 78258"
    heading="Home Theater Installation in Stone Oak, TX"
    subhead="Two completed Stone Oak theater builds in our portfolio. We are in this part of the city every week — no travel fee, no runaround, same team start to finish."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryCta="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
    imageSrc="/images/projects/asanka-theater/san-antonio-home-theater-project-cover.jpg"
    imageAlt="Custom home theater installation in Stone Oak San Antonio Texas with projection screen and surround sound"
    compact={true}
  />

  <TrustBar />

  <!-- Local context -->
  <section class="section bg-slate-surface">
    <div class="container-main">
      <p class="overline mb-3 reveal">Stone Oak, San Antonio</p>
      <h2 class="font-display text-h2 text-warm-white mb-6 reveal reveal-delay-1">
        Our Most Active San Antonio Market
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <p class="text-body-lg text-stone mb-6 reveal reveal-delay-2">
            Stone Oak is consistently our highest-volume area in San Antonio proper. The custom homes in the 78258 zip code — and the newer builds going up along US-281 in Rogers Ranch, Sonterra, The Vineyard, and the communities pushing north toward Bulverde — are exactly the kind of projects we are built for. Large floor plans, dedicated bonus rooms, covered outdoor spaces.
          </p>
          <p class="text-body text-stone mb-6 reveal reveal-delay-3">
            We have two dedicated theater installs in Stone Oak documented on this site. One is a finished retrofit in an existing home — Epson projector, Screen Innovations fixed-frame screen, Martin Logan on-wall speakers. The other is a new construction build we documented from pre-wire through final calibration. You can look at both before you ever call us.
          </p>
          <p class="text-body text-stone reveal reveal-delay-3">
            Beyond theater rooms, we have installed whole-house Sonos systems, outdoor speaker setups on covered patios, Samsung Frame TVs on fireplace walls, and security camera systems throughout Stone Oak and the surrounding north side. This is not unfamiliar territory.
          </p>
        </div>
        <div class="flex flex-col gap-6">
          <div class="card p-6 reveal reveal-delay-2">
            <h3 class="font-sans font-semibold text-warm-white mb-2">Two Stone Oak Theaters in Our Portfolio</h3>
            <p class="text-body-sm text-stone">We have completed theater builds in this specific market that you can view in detail — equipment lists, photos, project notes. No stock photos, no renders. Real installs in real Stone Oak homes.</p>
          </div>
          <div class="card p-6 reveal reveal-delay-3">
            <h3 class="font-sans font-semibold text-warm-white mb-2">Active Builder Relationships on the North Side</h3>
            <p class="text-body-sm text-stone">We work with custom home builders throughout north San Antonio. Pre-wire, rough-in, trim-out, and homeowner walkthrough — all handled. If your home is under construction, contact us now before the walls close.</p>
          </div>
          <div class="card p-6 reveal reveal-delay-4">
            <h3 class="font-sans font-semibold text-warm-white mb-2">In Stone Oak Every Week</h3>
            <p class="text-body-sm text-stone">No travel fee. We are in this part of the city regularly enough that scheduling a consultation is straightforward. We come to you, walk the space, and give you a real quote.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ProjectsGrid
    projects={projects}
    overline="Stone Oak Projects"
    heading="Two Completed Theater Builds in Stone Oak"
  />

  <TestimonialsSection featured={featured} />

  <!-- Services -->
  <section class="section bg-slate-surface">
    <div class="container-main">
      <p class="overline mb-3 reveal">What We Install in Stone Oak</p>
      <h2 class="font-display text-h2 text-warm-white mb-6 reveal reveal-delay-1">
        Every AV Service for North San Antonio Homes
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {[
          {
            title: 'Dedicated Home Theater',
            desc: '4K and laser projection, Dolby Atmos surround sound, tiered seating platforms, in-wall speakers, acoustic treatment. Designed around your specific room — not a template build.',
          },
          {
            title: 'Whole House Audio',
            desc: 'Sonos and multi-zone audio with in-ceiling speakers throughout the home. Kitchen, living room, master bedroom, patio — all controlled from your phone. Independent zones for different rooms.',
          },
          {
            title: 'TV Mounting & Media Rooms',
            desc: 'Large-format 4K displays, Samsung Frame TV installs on stone and tile walls, soundbar integration, clean in-wall wiring. Media room conversions with no visible cables.',
          },
          {
            title: 'Outdoor AV',
            desc: 'Covered patio speakers, outdoor TVs, and projector setups for north San Antonio\'s outdoor living spaces. Weatherproof, UV-rated, and built to handle the Texas heat.',
          },
        ].map(({ title, desc }) => (
          <div class="card p-7 reveal">
            <h3 class="font-sans font-semibold text-h4 text-warm-white mb-3">{title}</h3>
            <p class="text-body text-stone leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQAccordion
    heading="Stone Oak Home Theater — Frequently Asked Questions"
    faqs={faqs}
  />

  <CTASection
    heading="Ready to Get Started in Stone Oak?"
    body="Book a free consultation. We'll come to your Stone Oak home, look at the space, and put together a system built around how you actually use it."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>
