---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServicesGrid from '../../components/sections/ServicesGrid.astro';
import ProjectsGrid from '../../components/sections/ProjectsGrid.astro';
import TestimonialsSection from '../../components/sections/TestimonialsSection.astro';
import CTASection from '../../components/sections/CTASection.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Home Theater Installation Stone Oak",
  "provider": {
    "@type": "LocalBusiness",
    "name": "KZ Audio & Video",
    "url": "https://kzaudioandvideo.com",
    "telephone": "+12109814098"
  },
  "areaServed": "Stone Oak, TX",
  "description": "Custom home theater and AV installation in Stone Oak and north San Antonio.",
  "url": "https://kzaudioandvideo.com/home-theater-installation-stone-oak-san-antonio/"
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kzaudioandvideo.com" },
    { "@type": "ListItem", "position": 2, "name": "Home Theater Installation Stone Oak TX" }
  ]
};

const projects = [
  {
    title: 'Dedicated Home Theater — Canyon Lake TX',
    location: 'Canyon Lake, TX',
    service: 'Home Theater',
    description: 'Full theater room with custom leather power recliner seating, blue LED accent lighting, projection system, and in-wall surround sound.',
    imageSrc: '/images/projects/monty-theater/Canyon-Lake-Tesac-Home-Theater-Custom-Seating.jpeg.jpg',
    imageAlt: 'Custom home theater with leather recliners and blue LED lighting in Canyon Lake Texas',
  },
  {
    title: 'Dedicated Home Theater — San Antonio TX',
    location: 'San Antonio, TX',
    service: 'Home Theater',
    description: 'Epson projector, Screen Innovations fixed-frame screen, Martin Logan on-wall speakers, LED accent lighting.',
    imageSrc: '/images/projects/asanka-theater/theater-room-san-antonio-tx.jpg',
    imageAlt: 'Home theater installation in San Antonio Texas with projection screen and surround sound',
  },
];

const featured = {
  name: 'San Antonio Homeowner',
  location: 'San Antonio, TX',
  service: 'Home Theater Client — Nearly 10 Years',
  quote: "I've been a customer of KZ Audio for going on a decade. Kelly and crew have always been great to work with. They're honest and will recommend what actually works for your situation rather than upselling you on equipment you don't need.",
};
---

<BaseLayout
  title="Home Theater Installation Stone Oak TX | KZ Audio & Video"
  description="Custom home theater and AV installation in Stone Oak and north San Antonio. In the audio business since 1997. Call (210) 981-4098."
  schema={[schema, breadcrumb]}
>

  <HeroSection
    overline="Home Theater Installation · Stone Oak · North San Antonio · Since 2001"
    heading="Home Theater Installation in Stone Oak, TX"
    subhead="KZ Audio & Video designs and installs custom home theaters, whole-house audio, and outdoor AV systems in Stone Oak and across the North San Antonio. Stone Oak — one of San Antonio's premier north-side communities, home to a large concentration of custom homes. In the audio business since 1997."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryCta="Or call: (210) 981-4098"
    secondaryHref="tel:2109814098"
    imageSrc="/images/projects/flat-tvs/samsung-frame-tv-marble-wall-san-antonio.jpg"
    imageAlt="Custom home theater and AV installation in Stone Oak North San Antonio Texas"
  />

  <TrustBar />

  <ServicesGrid
    intro="KZ Audio & Video serves Stone Oak and the surrounding North San Antonio. We design, install, and service custom home AV systems."
  />

  <ProjectsGrid
    projects={projects}
    overline="Recent Projects"
    heading="Home Theater Installs Near Stone Oak"
  />

  <TestimonialsSection featured={featured} />

  <!-- Stone Oak Local Context -->
  <section class="section bg-charcoal">
    <div class="container-main">
      <p class="overline mb-3 reveal">About Stone Oak</p>
      <h2 class="font-display text-h2 text-warm-white mb-8 reveal reveal-delay-1">
        Our Busiest Zip Code in San Antonio
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-12">
        <div>
          <p class="text-body-lg text-stone mb-6 reveal reveal-delay-2">
            Stone Oak is one of San Antonio's premier residential neighborhoods and consistently one of our highest-volume service areas. The custom homes in the 78258 area — and the newer builds going up in the communities just north along US-281 — represent serious investment, and the homeowners here expect AV work that matches the quality of the rest of the house. That's the standard we hold ourselves to.
          </p>
          <p class="text-body text-stone reveal reveal-delay-3">
            We've installed dedicated theaters, whole-house Sonos audio systems, outdoor speaker setups, and Samsung Frame TVs in Stone Oak homes for over two decades. Media room conversions, dedicated theater builds, new construction pre-wire — it's all familiar territory. If you're in Stone Oak and want AV done right, this is a short conversation.
          </p>
        </div>
        <div class="flex flex-col gap-6">
          <div class="reveal reveal-delay-2">
            <h3 class="font-sans font-semibold text-warm-white mb-2">Stone Oak Is Our Most Active Market</h3>
            <p class="text-body-sm text-stone">We are in Stone Oak regularly. We know the builders active on the north side, we know the neighborhoods, and we're not making a special trip — it's where a significant share of our work happens.</p>
          </div>
          <div class="reveal reveal-delay-3">
            <h3 class="font-sans font-semibold text-warm-white mb-2">One Team, Every Install</h3>
            <p class="text-body-sm text-stone">Kelly, Billy, and Julian do every install in Stone Oak. You'll see the same faces on day one of the install that you spoke with during the consultation.</p>
          </div>
          <div class="reveal reveal-delay-4">
            <h3 class="font-sans font-semibold text-warm-white mb-2">Free Consultation — We Come to You</h3>
            <p class="text-body-sm text-stone">We come to your home in Stone Oak, walk the space, and give you a real quote. No charge, no obligation, no sales pressure.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Get Started in Stone Oak?"
    body="Book a free, no-pressure consultation. We'll come to your home in Stone Oak and talk through what's possible."
    ctaLabel="Book a Free Consultation"
    ctaHref="/contact-kz-audio-video-san-antonio-tx/"
    secondaryLabel="Call (210) 981-4098"
    secondaryHref="tel:2109814098"
  />

</BaseLayout>
